---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Never miss a lead again. JobsiteRank gives plumbers a free conversion website, missed-call text-back, review automation, and a real lead pipeline — starting at $297/month.",
}: Props = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const showFloatingCta = path !== "/contact";

const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "https://jobsiterank.com";
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImage = `${siteUrl}/og-image.svg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Standard SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph (Facebook, LinkedIn, Slack, iMessage, WhatsApp) -->
    <meta property="og:site_name" content="JobsiteRank" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="JobsiteRank — never miss a lead again" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="JobsiteRank — never miss a lead again" />

    <!-- Brand color (mobile address-bar tint) -->
    <meta name="theme-color" content="#10B981" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="bg-[color:var(--color-paper)] text-[color:var(--color-ink)]">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    {showFloatingCta && (
      <a
        href="/contact"
        id="floating-cta"
        class="md:hidden fixed bottom-4 right-4 z-50 inline-flex items-center gap-2 bg-[color:var(--color-accent)] text-[color:var(--color-paper)] font-semibold text-[0.93rem] px-5 py-3 rounded-full shadow-[0_8px_24px_rgb(16_185_129_/_0.4)]"
        style="padding-bottom: max(0.75rem, env(safe-area-inset-bottom));"
        aria-label="Book a demo"
      >
        Book a demo →
      </a>

      <script is:inline>
        (function () {
          const cta = document.getElementById("floating-cta");
          const panel = document.getElementById("mobile-nav-panel");
          if (!cta || !panel) return;
          const sync = function () {
            if (!panel.classList.contains("hidden")) cta.style.display = "none";
            else cta.style.display = "";
          };
          new MutationObserver(sync).observe(panel, { attributes: true, attributeFilter: ["class"] });
        })();
      </script>
    )}
  </body>
</html>
