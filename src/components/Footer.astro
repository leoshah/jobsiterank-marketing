---
const year = new Date().getFullYear();
---

<footer class="dark-section">
  <div class="grain"></div>
  <div class="container-dossier py-16">
    <div class="grid gap-10 md:grid-cols-[2fr_1fr_1fr_1fr] items-start">
      <div>
        <div class="flex items-center gap-3 mb-5">
          <span class="grid place-items-center w-9 h-9 border border-[color:var(--color-paper)] font-mono text-[0.7rem] tracking-[0.2em]">JR</span>
          <span class="font-display text-[1.1rem]">JobsiteRank</span>
        </div>
        <p class="text-[color:var(--color-paper)]/70 max-w-sm leading-relaxed text-[0.95rem]">
          Editorial marketing system for trades businesses in Pasadena, the San Gabriel Valley, and Greater Los Angeles. One flat price. No tiers.
        </p>
        <div class="meta mt-6">File 000 · Master dossier</div>
      </div>

      <div>
        <div class="eyebrow mb-4">Pages</div>
        <ul class="space-y-2 text-[0.95rem]">
          <li><a href="/" class="hover:text-[color:var(--color-amber)]">Home</a></li>
          <li><a href="/pricing" class="hover:text-[color:var(--color-amber)]">Pricing</a></li>
          <li><a href="/case-studies" class="hover:text-[color:var(--color-amber)]">Case studies</a></li>
          <li><a href="/contact" class="hover:text-[color:var(--color-amber)]">Contact</a></li>
        </ul>
      </div>

      <div>
        <div class="eyebrow mb-4">Service area</div>
        <ul class="space-y-2 text-[0.95rem] text-[color:var(--color-paper)]/80">
          <li>Pasadena</li>
          <li>San Gabriel Valley</li>
          <li>Greater Los Angeles</li>
        </ul>
      </div>

      <div>
        <div class="eyebrow mb-4">Direct line</div>
        <ul class="space-y-2 text-[0.95rem]">
          <li><a href="mailto:hello@jobsiterank.com" class="hover:text-[color:var(--color-amber)]">hello@jobsiterank.com</a></li>
          <li><a href="tel:+16265550199" class="hover:text-[color:var(--color-amber)]">(626) 555-0199</a></li>
          <li class="text-[color:var(--color-paper)]/60">Mon–Fri · 8a–6p PT</li>
        </ul>
      </div>
    </div>

    <div class="mt-14 pt-6 border-t border-[color:var(--color-rule-dark)] flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div class="meta">© {year} JobsiteRank · All rights reserved</div>
      <div class="meta">Built in Pasadena, CA · Edition 01</div>
    </div>
  </div>
</footer>
