---
const navLinks: Array<{ href: string; label: string }> = [
  { href: "/", label: "Home" },
  { href: "/pricing", label: "Pricing" },
  { href: "/case-studies", label: "Case studies" },
  { href: "/contact", label: "Contact" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-40 bg-[color:var(--color-paper)]/85 backdrop-blur-md border-b border-[color:var(--color-slate-200)]">
  <div class="container-page flex items-center justify-between py-4">
    <a href="/" class="flex items-center gap-2.5 group">
      <span class="grid place-items-center w-9 h-9 rounded-xl bg-[color:var(--color-ink)] text-[color:var(--color-accent)] font-display text-[0.9rem] font-bold">
        JR
      </span>
      <span class="font-display text-[1.1rem] font-semibold tracking-tight text-[color:var(--color-ink)]">
        JobsiteRank
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => {
        const linkPath = link.href.replace(/\/$/, "") || "/";
        const active = path === linkPath;
        return (
          <a
            href={link.href}
            class:list={[
              "px-3.5 py-2 rounded-full text-[0.93rem] font-medium transition-colors",
              active
                ? "bg-[color:var(--color-slate-100)] text-[color:var(--color-ink)]"
                : "text-[color:var(--color-slate-600)] hover:text-[color:var(--color-ink)] hover:bg-[color:var(--color-slate-50)]",
            ]}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <div class="hidden md:flex items-center gap-2">
      <a href="tel:+16265550199" class="text-[0.93rem] font-medium text-[color:var(--color-slate-700)] hover:text-[color:var(--color-ink)] transition-colors mr-2">
        (626) 555-0199
      </a>
      <a href="/contact" class="btn-accent text-[0.9rem] !py-2.5 !px-5">
        Book a demo
      </a>
    </div>

    <button
      type="button"
      id="mobile-nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
      class="md:hidden grid place-items-center w-10 h-10 rounded-full border border-[color:var(--color-slate-200)] text-[color:var(--color-ink)]"
    >
      <span class="sr-only">Menu</span>
      <span id="mobile-nav-icon" class="block w-4 h-[1.5px] bg-current relative before:content-[''] before:absolute before:left-0 before:right-0 before:-top-[5px] before:h-[1.5px] before:bg-current before:transition-transform after:content-[''] after:absolute after:left-0 after:right-0 after:-bottom-[5px] after:h-[1.5px] after:bg-current after:transition-transform transition-colors"></span>
    </button>
  </div>

  <div
    id="mobile-nav-panel"
    class="md:hidden hidden border-t border-[color:var(--color-slate-200)] bg-[color:var(--color-paper)]"
  >
    <nav class="container-page py-5 flex flex-col gap-1">
      {navLinks.map((link) => {
        const linkPath = link.href.replace(/\/$/, "") || "/";
        const active = path === linkPath;
        return (
          <a
            href={link.href}
            class:list={[
              "px-3 py-3 rounded-xl text-[1rem] font-medium",
              active
                ? "bg-[color:var(--color-slate-100)] text-[color:var(--color-ink)]"
                : "text-[color:var(--color-slate-700)] hover:bg-[color:var(--color-slate-50)]",
            ]}
          >
            {link.label}
          </a>
        );
      })}
      <a href="/contact" class="btn-accent mt-4 w-full">Book a demo</a>
      <a href="tel:+16265550199" class="text-center text-[color:var(--color-slate-600)] mt-3 text-[0.9rem]">
        Or call (626) 555-0199
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById("mobile-nav-toggle");
    const panel = document.getElementById("mobile-nav-panel");
    const icon = document.getElementById("mobile-nav-icon");
    if (!btn || !panel || !icon) return;

    function close() {
      panel.classList.add("hidden");
      btn.setAttribute("aria-expanded", "false");
      icon.classList.remove("nav-open");
    }
    function open() {
      panel.classList.remove("hidden");
      btn.setAttribute("aria-expanded", "true");
      icon.classList.add("nav-open");
    }

    btn.addEventListener("click", function () {
      if (panel.classList.contains("hidden")) open();
      else close();
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") close();
    });

    window.addEventListener("resize", function () {
      if (window.innerWidth >= 768) close();
    });
  })();
</script>

<style>
  #mobile-nav-icon.nav-open {
    background-color: transparent;
  }
  #mobile-nav-icon.nav-open::before {
    transform: translateY(5px) rotate(45deg);
  }
  #mobile-nav-icon.nav-open::after {
    transform: translateY(-5px) rotate(-45deg);
  }
</style>
