---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CASE_STUDIES, CATEGORIES, type CaseStudy } from "../../data/caseStudies";

export function getStaticPaths() {
  return CASE_STUDIES.map((cs) => ({
    params: { slug: cs.slug },
    props: { cs },
  }));
}

interface Props {
  cs: CaseStudy;
}

const { cs } = Astro.props;
const categoryMeta = CATEGORIES.find((c) => c.key === cs.category);
const categoryLabel = categoryMeta ? categoryMeta.label : cs.category;
---

<BaseLayout
  title={`${cs.business} — case study · JobsiteRank`}
  description={`${cs.business} (${cs.city}, ${cs.state}) — ${cs.cardHook}`}
>
  <!-- ─── Header ─── -->
  <section class="bg-[color:var(--color-cream)] relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[color:var(--color-mint)]/40 via-transparent to-transparent pointer-events-none"></div>
    <div class="container-page relative section-padding-tight md:!pt-16 md:!pb-12">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-baseline gap-4 flex-wrap">
          <span class="font-display text-[1.05rem] text-[color:var(--color-accent-dark)] font-semibold">{cs.business}</span>
          <span class="text-[0.9rem] text-[color:var(--color-slate-500)]">{cs.city}, {cs.state}</span>
        </div>

        <h1 class="font-display text-[2.4rem] sm:text-[3rem] md:text-[3.6rem] leading-[1.05] tracking-tight mt-3 text-[color:var(--color-ink)]">
          {cs.titleStart}
          <span class="block mt-1 text-[color:var(--color-accent-dark)]">{cs.titleAccent}</span>
        </h1>

        <p class="mt-6 text-[1.05rem] md:text-[1.12rem] leading-relaxed text-[color:var(--color-slate-600)] max-w-3xl">
          {cs.intro}
        </p>
      </div>
    </div>
  </section>

  <!-- ─── Body ─── -->
  <section class="bg-[color:var(--color-paper)]">
    <div class="container-page section-padding-tight md:!py-16">
      <div class="max-w-5xl mx-auto">
        <!-- Intake + before/after -->
        <div class="grid lg:grid-cols-[1.2fr_1fr] gap-8 lg:gap-12 mb-16">
          <div class="card-flat">
            <div class="eyebrow mb-5">Intake</div>
            <dl class="grid grid-cols-[auto_1fr] gap-x-8 gap-y-4">
              {cs.intakeFacts.map((f) => (
                <>
                  <dt class="text-[0.85rem] font-semibold text-[color:var(--color-slate-500)] whitespace-nowrap uppercase tracking-wide">{f.label}</dt>
                  <dd class="text-[0.95rem] text-[color:var(--color-ink)]">{f.value}</dd>
                </>
              ))}
            </dl>
          </div>

          <aside class="card-mint">
            <div class="eyebrow mb-5">Before / after</div>
            <div class="space-y-5">
              {cs.beforeAfter.map((row, idx) => (
                <div class={idx > 0 ? "border-t border-[color:var(--color-accent-soft)] pt-4" : ""}>
                  <div class="flex items-baseline justify-between gap-3">
                    <span class="font-display font-semibold text-[1rem] text-[color:var(--color-ink)]">{row.label}</span>
                    <span class="font-display text-[1.1rem] font-bold text-[color:var(--color-accent-dark)] whitespace-nowrap">{row.delta}</span>
                  </div>
                  <div class="mt-1.5 text-[0.88rem] text-[color:var(--color-slate-600)]">{row.detail}</div>
                </div>
              ))}
            </div>
          </aside>
        </div>

        <!-- Metrics -->
        <div class="mb-16">
          <div class="eyebrow mb-5">Metrics</div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {cs.metrics.map((m) => (
              <div class="card-flat">
                <div class="font-display text-[2.4rem] leading-none text-[color:var(--color-accent-dark)] font-semibold">{m.value}</div>
                <div class="text-[0.88rem] text-[color:var(--color-slate-600)] mt-3">{m.label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Timeline -->
        <div class="mb-16">
          <div class="eyebrow mb-5">Engagement timeline</div>
          <ol class="space-y-3">
            {cs.timeline.map((entry, idx) => (
              <li class="card-flat">
                <div class="grid md:grid-cols-[160px_1fr] gap-4 md:gap-8">
                  <div>
                    <div class="text-[0.78rem] font-semibold uppercase tracking-wide text-[color:var(--color-accent-dark)]">Step {idx + 1}</div>
                    <div class="font-display text-[1rem] font-semibold text-[color:var(--color-ink)] mt-1.5">{entry.week}</div>
                  </div>
                  <div>
                    <div class="font-display text-[1.1rem] font-semibold text-[color:var(--color-ink)]">{entry.label}</div>
                    <p class="mt-2 text-[0.95rem] leading-relaxed text-[color:var(--color-slate-600)]">{entry.detail}</p>
                  </div>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <!-- Quote -->
        <div class="card-dark">
          <div class="text-[color:var(--color-warning)] text-[1.05rem] mb-4">★ ★ ★ ★ ★</div>
          <blockquote class="font-display text-[1.4rem] md:text-[1.7rem] leading-snug text-[color:var(--color-paper)]">
            "{cs.quote}"
          </blockquote>
          <div class="mt-6 flex items-center gap-3">
            <div class="grid place-items-center w-11 h-11 rounded-full bg-[color:var(--color-accent)] text-[color:var(--color-ink)] font-display font-bold text-[0.95rem]">
              {cs.quoteInitials}
            </div>
            <div>
              <div class="font-semibold text-[color:var(--color-paper)] text-[0.95rem]">{cs.quoteAuthor}</div>
              <div class="text-[0.85rem] text-[color:var(--color-paper)]/65">{cs.quoteAttribution}</div>
            </div>
          </div>
        </div>

        <!-- Back nav -->
        <div class="mt-10 flex flex-wrap items-center justify-between gap-4">
          <a href="/case-studies" class="btn-outline">← All case studies</a>
          <a href="/contact" class="btn-accent">Book a demo →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Bottom CTA ─── -->
  <section class="bg-[color:var(--color-cream)]">
    <div class="container-page section-padding-tight md:!py-16">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-display text-[1.8rem] md:text-[2.4rem] leading-[1.05] tracking-tight text-[color:var(--color-ink)]">
          See if your shop fits the next file.
        </h2>
        <p class="mt-4 text-[1rem] leading-relaxed text-[color:var(--color-slate-600)] max-w-xl mx-auto">
          Twenty-minute demo. We pull up your Google Business Profile live and tell you straight whether the system would move the needle.
        </p>
        <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
          <a href="/contact" class="btn-accent">Book a demo →</a>
          <a href="/case-studies" class="btn-outline">Read more cases</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
