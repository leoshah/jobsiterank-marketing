---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CASE_STUDIES, CATEGORIES, type CaseCategory } from "../../data/caseStudies";

const counts: Record<CaseCategory | "all", number> = {
  all: CASE_STUDIES.length,
  "text-back": 0,
  "re-activation": 0,
  reviews: 0,
  leads: 0,
};
for (const cs of CASE_STUDIES) counts[cs.category]++;

const categoryShort: Record<CaseCategory, string> = Object.fromEntries(
  CATEGORIES.map((c) => [c.key, c.short])
) as Record<CaseCategory, string>;
---

<BaseLayout
  title="Case studies — JobsiteRank"
  description="11 case files from plumbing shops across the US: missed-call-text-back, re-activation campaigns, reviews & replies, lead generation."
>
  <!-- ─── Header ─── -->
  <section class="bg-[color:var(--color-cream)] relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[color:var(--color-mint)]/40 via-transparent to-transparent pointer-events-none"></div>
    <div class="container-page relative section-padding-tight md:!pt-20 md:!pb-16">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="font-display text-[2.4rem] sm:text-[3.2rem] md:text-[3.8rem] leading-[1.05] tracking-tight text-[color:var(--color-ink)]">
          Real shops. Real numbers.
        </h1>
        <p class="mt-6 text-[1.1rem] leading-relaxed text-[color:var(--color-slate-600)] max-w-2xl mx-auto">
          Outcomes from plumbing shops across the country — text-back wins, re-activation campaigns, review-engine results, lead-gen lifts. Click any file to read the engagement.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── Filter ─── -->
  <section class="bg-[color:var(--color-paper)] -mt-8 relative z-10">
    <div class="container-page">
      <div
        id="cs-filter"
        class="flex flex-wrap gap-2 justify-center bg-[color:var(--color-paper)] border border-[color:var(--color-slate-200)] rounded-full p-1.5 max-w-3xl mx-auto shadow-sm"
        role="tablist"
        aria-label="Filter case studies"
      >
        <button
          type="button"
          class="cs-filter-btn px-4 py-2 rounded-full text-[0.85rem] font-semibold transition-colors bg-[color:var(--color-ink)] text-[color:var(--color-paper)]"
          data-filter="all"
          aria-pressed="true"
        >
          All <span class="opacity-60 ml-1">{counts.all}</span>
        </button>
        {CATEGORIES.map((cat) => (
          <button
            type="button"
            class="cs-filter-btn px-4 py-2 rounded-full text-[0.85rem] font-semibold transition-colors text-[color:var(--color-slate-600)] hover:bg-[color:var(--color-slate-50)]"
            data-filter={cat.key}
            aria-pressed="false"
          >
            {cat.short} <span class="opacity-60 ml-1">{counts[cat.key]}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Grid ─── -->
  <section class="bg-[color:var(--color-paper)]">
    <div class="container-page section-padding">
      <div id="cs-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {CASE_STUDIES.map((cs) => (
          <a
            href={`/case-studies/${cs.slug}`}
            class="cs-card card-soft group"
            data-category={cs.category}
          >
            <div class="flex items-baseline justify-between mb-4">
              <span class="tag-pill tag-pill-accent">{categoryShort[cs.category]}</span>
              <span class="text-[0.78rem] font-medium text-[color:var(--color-slate-500)]">{cs.city}, {cs.state}</span>
            </div>

            <h3 class="font-display text-[1.3rem] font-semibold leading-tight text-[color:var(--color-ink)]">{cs.business}</h3>
            <div class="text-[0.85rem] text-[color:var(--color-slate-500)] mt-1">{cs.trade}</div>

            <p class="mt-4 text-[0.93rem] leading-relaxed text-[color:var(--color-slate-600)]">
              {cs.cardHook}
            </p>

            <div class="mt-5 pt-5 border-t border-[color:var(--color-slate-200)] flex items-baseline justify-between">
              <div>
                <div class="font-display text-[1.6rem] leading-none text-[color:var(--color-accent-dark)] font-semibold">{cs.cardMetricValue}</div>
                <div class="text-[0.78rem] text-[color:var(--color-slate-500)] mt-1.5">{cs.cardMetricLabel}</div>
              </div>
              <span class="text-[0.85rem] font-semibold text-[color:var(--color-ink)] group-hover:text-[color:var(--color-accent-dark)]">
                Read →
              </span>
            </div>
          </a>
        ))}
      </div>

      <p
        id="cs-empty"
        class="hidden text-center text-[0.9rem] text-[color:var(--color-slate-500)] py-16"
      >
        No case files in this category yet.
      </p>

      <p class="mt-12 text-center text-[0.85rem] text-[color:var(--color-slate-500)] max-w-2xl mx-auto">
        Cases tagged "representative" are illustrative engagements composed for this dossier. Real published cases will replace them as engagements close.
      </p>
    </div>
  </section>

  <!-- ─── Bottom CTA ─── -->
  <section class="bg-[color:var(--color-ink)] relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[color:var(--color-accent)]/15 via-transparent to-[color:var(--color-accent)]/5 pointer-events-none"></div>
    <div class="container-page section-padding relative">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-display text-[2.2rem] md:text-[3rem] leading-[1.05] tracking-tight text-[color:var(--color-paper)]">
          Want your shop in the next file?
        </h2>
        <p class="mt-5 text-[1.1rem] leading-relaxed text-[color:var(--color-paper)]/75 max-w-2xl mx-auto">
          We pick three new engagements per quarter so the work stays good. The demo is where it starts.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/contact" class="btn-accent text-[1rem] !py-4 !px-7">Book a demo →</a>
          <a href="/pricing" class="inline-flex items-center gap-2 text-[color:var(--color-paper)] text-[1rem] font-medium px-6 py-4 hover:text-[color:var(--color-accent)] transition-colors">
            See pricing →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const filterEl = document.getElementById("cs-filter");
    const gridEl = document.getElementById("cs-grid");
    const emptyEl = document.getElementById("cs-empty");
    if (!filterEl || !gridEl || !emptyEl) return;

    const buttons = Array.from(filterEl.querySelectorAll(".cs-filter-btn"));
    const cards = Array.from(gridEl.querySelectorAll(".cs-card"));

    function setActive(filter) {
      buttons.forEach(function (b) {
        const isActive = b.getAttribute("data-filter") === filter;
        b.setAttribute("aria-pressed", isActive ? "true" : "false");
        if (isActive) {
          b.classList.add("bg-[color:var(--color-ink)]", "text-[color:var(--color-paper)]");
          b.classList.remove("text-[color:var(--color-slate-600)]", "hover:bg-[color:var(--color-slate-50)]");
        } else {
          b.classList.remove("bg-[color:var(--color-ink)]", "text-[color:var(--color-paper)]");
          b.classList.add("text-[color:var(--color-slate-600)]", "hover:bg-[color:var(--color-slate-50)]");
        }
      });

      let visible = 0;
      cards.forEach(function (c) {
        const cat = c.getAttribute("data-category");
        const show = filter === "all" || cat === filter;
        c.style.display = show ? "" : "none";
        if (show) visible++;
      });

      emptyEl.classList.toggle("hidden", visible !== 0);
    }

    buttons.forEach(function (b) {
      b.addEventListener("click", function () {
        const filter = b.getAttribute("data-filter") || "all";
        setActive(filter);
      });
    });
  })();
</script>
