---
import BaseLayout from "../layouts/BaseLayout.astro";

interface ProductCategory {
  eyebrow: string;
  title: string;
  description: string;
  products: Array<{ name: string; description: string }>;
  visual?: "phone" | "list" | "stars" | "dashboard";
}

const productCategories: ProductCategory[] = [
  {
    eyebrow: "Get found online",
    title: "If people can't find you on Google, they won't call you.",
    description: "We fix that with a website built to rank, get clicks, and turn them into customers.",
    products: [
      { name: "Free conversion website", description: "Mobile-first, click-to-call. Built so Google can read it and customers want to dial." },
      { name: "On-site SEO", description: "Pages structured so Google understands what you do and where you serve." },
      { name: "Service area pages", description: "Show up in 'near me' searches across every zip code you cover." },
      { name: "Google Business Profile posts", description: "Two posts a week to keep your profile fresh and ranking." },
      { name: "Directory listings", description: "Get listed in 80+ trusted directories — consistent name, address, phone." },
    ],
    visual: "list",
  },
  {
    eyebrow: "Capture more leads",
    title: "Turn missed calls into new jobs.",
    description: "Automatically follow up with every missed call so you never lose a lead.",
    products: [
      { name: "Missed-call text-back", description: "A text is sent within 30 seconds when you can't answer." },
      { name: "Two-way SMS inbox", description: "Send and receive texts from your business number — works like regular texting." },
      { name: "Dedicated business number", description: "Port your existing number or get a new one. Yours forever." },
      { name: "Mobile messaging app", description: "All texts saved and organized in one place. Reply faster, win more jobs." },
    ],
    visual: "phone",
  },
  {
    eyebrow: "Get more reviews",
    title: "Get more 5-star reviews — without the risk.",
    description: "We route happy customers to Google and send unhappy ones to a private form.",
    products: [
      { name: "Review request automation", description: "Every completed job gets a follow-up text asking for a review." },
      { name: "Smart routing", description: "Happy customers go to Google. Unhappy ones go to a private form for you." },
      { name: "Smart cooldown", description: "Repeat customers don't get spammed. We pace requests intelligently." },
      { name: "Review replies", description: "Our team writes a thoughtful response to every review within 24 hours." },
    ],
    visual: "stars",
  },
  {
    eyebrow: "Run your business",
    title: "Manage your leads without the chaos.",
    description: "Everything organized so you can track, follow up, and close more jobs.",
    products: [
      { name: "Full CRM with lead pipeline", description: "Calls, texts, jobs — all tracked together. See exactly where each one stands." },
      { name: "Full branded mobile CRM", description: "Manage everything from your phone. App and messaging branded to you." },
      { name: "Quarterly re-activation campaigns", description: "Wake up dormant past customers with a seasonal SMS. Repeat work, no ad spend." },
      { name: "Weekly missed-call recovery report", description: "See every missed call and how many we recovered — straight to your inbox." },
      { name: "Monthly performance reports", description: "Reviews gained, calls captured, leads booked. One page, every month." },
    ],
    visual: "dashboard",
  },
];

interface FaqItem {
  q: string;
  a: string;
}

const faqs: FaqItem[] = [
  {
    q: "How fast does the missed-call text-back fire?",
    a: "Under 30 seconds, every time. The customer gets an SMS from your business number with a friendly 'sorry I missed you, what's the address?' so the conversation starts before they dial the next plumber.",
  },
  {
    q: "Do I get to keep my phone number?",
    a: "Yes. Port your existing business number or pick a new one — either way it stays yours forever. Cancel us, you keep the number.",
  },
  {
    q: "What's the difference between the three plans?",
    a: "Never Miss a Lead ($197) catches every call with text-back + a free website. Lead + Review Engine ($297) adds review automation so you start out-ranking competitors. Local Authority ($497) is the full system — we own the local map for you with citations, GBP posts, and a branded mobile CRM.",
  },
  {
    q: "Is the website really free with every tier?",
    a: "Yes. Even the $197 entry tier ships with a free conversion-focused mobile-first website. No setup fee. The site is built to drive phone calls, not just traffic.",
  },
  {
    q: "How is this different from HomeAdvisor or Angi?",
    a: "Lead-gen apps rent you a lead, then re-rent it to three of your competitors. We build the channel that you own — your own ranking on Google, your own phone, your own review profile. Cancel us and you keep all of it.",
  },
  {
    q: "What trades do you serve?",
    a: "Plumbing, all sub-specialties — residential, commercial, drain & sewer, emergency, tankless, re-pipe. We work with shops across the US.",
  },
];

const stats = [
  { value: "100+", label: "Plumbing shops served" },
  { value: "12s", label: "Avg auto-text response" },
  { value: "4.9★", label: "Average customer rating" },
  { value: "$0", label: "Setup fee, every tier" },
];

const tiers = [
  {
    name: "Never Miss a Lead",
    price: 197,
    tagline: "Stop losing jobs to voicemail.",
    features: [
      "Free conversion-focused website",
      "Missed-call text-back (under 30s)",
      "Dedicated business number",
      "Two-way SMS inbox + mobile messaging app",
      "Weekly missed-call recovery report",
    ],
    badge: null,
  },
  {
    name: "Lead + Review Engine",
    price: 297,
    tagline: "Catch every lead. Stack every review.",
    features: [
      "Everything in Never Miss a Lead",
      "Review request automation",
      "Smart routing (happy → Google)",
      "Smart cooldown per customer",
      "Monthly review-volume report",
    ],
    badge: "Most popular",
  },
  {
    name: "Local Authority",
    price: 497,
    tagline: "The full system. We own the local map.",
    features: [
      "Everything in Lead + Review Engine",
      "Google Business Profile posts (2×/wk)",
      "NAP citations (80+ directories)",
      "Review responses by our team",
      "Full CRM with lead pipeline",
      "Full branded mobile CRM",
      "Quarterly re-activation campaigns",
    ],
    badge: "Flagship",
  },
];

const testimonials = [
  {
    quote: "First week the missed-call texts went live we booked four after-hours jobs. Paid for the bundle for six months.",
    name: "Marco D.",
    business: "Plumbing Geeks · Pasadena, CA",
    initials: "MD",
  },
  {
    quote: "We were losing $40k a winter to voicemail and didn't even know it. The text-back caught all of it.",
    name: "Karen M.",
    business: "Mile-High Pipeworks · Denver, CO",
    initials: "KM",
  },
  {
    quote: "Texted 1,800 dormant customers. Booked 87 jobs in two weeks. Best $71k week we've ever had.",
    name: "Diego L.",
    business: "Saguaro Plumbing · Phoenix, AZ",
    initials: "DL",
  },
];
---

<BaseLayout title="JobsiteRank — marketing system for plumbers">
  <!-- ─── Hero ─── -->
  <section class="bg-[color:var(--color-cream)] relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[color:var(--color-mint)]/40 via-transparent to-transparent pointer-events-none"></div>
    <div class="container-page relative section-padding-tight md:!pt-20 md:!pb-24">
      <div class="grid lg:grid-cols-[1.15fr_1fr] gap-12 lg:gap-16 items-center">
        <div>
          <span class="eyebrow-mint">★ Built for plumbers</span>
          <h1 class="font-display text-[2.4rem] sm:text-[3.2rem] md:text-[3.8rem] lg:text-[4.2rem] leading-[1.02] tracking-tight mt-6 text-[color:var(--color-ink)]">
            Stop losing jobs to voicemail.
            <span class="block mt-2 text-[color:var(--color-accent-dark)]">Get found, get called, get booked.</span>
          </h1>
          <p class="mt-6 max-w-xl text-[1.1rem] md:text-[1.18rem] leading-relaxed text-[color:var(--color-slate-600)]">
            JobsiteRank gives plumbers a conversion-focused website, missed-call text-back, review automation, and a real lead pipeline — all in one stack, starting at <strong class="text-[color:var(--color-ink)]">$197/month</strong>.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a href="/contact" class="btn-accent text-[1rem] !py-4 !px-7">
              Book a demo →
            </a>
            <a href="/pricing" class="btn-outline text-[1rem] !py-4 !px-7">
              See pricing
            </a>
          </div>

          <div class="mt-8 flex items-center gap-3 text-[color:var(--color-slate-500)] text-[0.9rem]">
            <span class="text-[color:var(--color-warning)] text-[1rem]">★ ★ ★ ★ ★</span>
            <span>4.9 across 100+ plumbing shops</span>
            <span class="hidden sm:inline">·</span>
            <span class="hidden sm:inline">Cancel anytime</span>
          </div>
        </div>

        <!-- Phone mockup with text thread -->
        <div class="relative">
          <div class="absolute -inset-4 md:-inset-8 bg-gradient-to-br from-[color:var(--color-accent-soft)] to-transparent rounded-[3rem] blur-2xl pointer-events-none"></div>
          <div class="relative mx-auto max-w-sm bg-[color:var(--color-ink)] rounded-[2.5rem] p-3 shadow-xl">
            <div class="bg-[color:var(--color-paper)] rounded-[2rem] p-5 min-h-[460px]">
              <div class="flex items-center justify-between mb-4 pb-3 border-b border-[color:var(--color-slate-200)]">
                <div class="flex items-center gap-2.5">
                  <span class="grid place-items-center w-8 h-8 rounded-full bg-[color:var(--color-mint)] text-[color:var(--color-accent-dark)] text-[0.85rem]">✆</span>
                  <div>
                    <div class="text-[0.78rem] font-semibold text-[color:var(--color-ink)]">JobsiteRank</div>
                    <div class="text-[0.7rem] text-[color:var(--color-slate-500)]">Live · Pasadena, CA</div>
                  </div>
                </div>
                <span class="text-[0.7rem] text-[color:var(--color-slate-400)]">4:23 PM</span>
              </div>

              <div class="bg-[color:var(--color-slate-50)] rounded-xl p-3 mb-3 flex items-center gap-2.5">
                <span class="text-[color:var(--color-slate-400)] text-[1rem]">✆</span>
                <div class="flex-1">
                  <div class="text-[0.78rem] font-medium text-[color:var(--color-ink)]">Missed call · (818) ▓▓▓-0142</div>
                  <div class="text-[0.7rem] text-[color:var(--color-slate-500)]">No voicemail · 4:23 PM</div>
                </div>
              </div>

              <div class="space-y-3">
                <div class="flex justify-end">
                  <div class="max-w-[85%]">
                    <div class="bg-[color:var(--color-accent)] text-[color:var(--color-paper)] px-3.5 py-2.5 rounded-2xl rounded-br-md text-[0.85rem] leading-snug">
                      Hey, this is Marco at Plumbing Geeks — sorry I missed your call. What's the address &amp; what's going on?
                    </div>
                    <div class="text-[0.65rem] text-[color:var(--color-slate-400)] text-right mt-1">Auto-text · 4:23 PM</div>
                  </div>
                </div>

                <div class="flex justify-start">
                  <div class="max-w-[85%]">
                    <div class="bg-[color:var(--color-slate-100)] text-[color:var(--color-ink)] px-3.5 py-2.5 rounded-2xl rounded-bl-md text-[0.85rem] leading-snug">
                      1432 Linda Vista. Water heater leaking everywhere. Can you come now??
                    </div>
                    <div class="text-[0.65rem] text-[color:var(--color-slate-400)] mt-1">Customer · 4:25 PM</div>
                  </div>
                </div>

                <div class="flex justify-end">
                  <div class="max-w-[85%]">
                    <div class="bg-[color:var(--color-accent)] text-[color:var(--color-paper)] px-3.5 py-2.5 rounded-2xl rounded-br-md text-[0.85rem] leading-snug">
                      On the way. ETA 35 min. Shut off the water at the wall valve if you can.
                    </div>
                    <div class="text-[0.65rem] text-[color:var(--color-slate-400)] text-right mt-1">Marco · 4:26 PM</div>
                  </div>
                </div>
              </div>

              <div class="mt-5 pt-4 border-t border-[color:var(--color-slate-200)] flex items-center justify-between">
                <div>
                  <div class="text-[0.85rem] font-semibold text-[color:var(--color-ink)]">Job booked in 3 min</div>
                  <div class="text-[0.7rem] text-[color:var(--color-slate-500)]">Zero touches from you</div>
                </div>
                <span class="tag-pill tag-pill-accent text-[0.68rem]">+$1,840 job</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Trust bar / stats ─── -->
  <section class="border-y border-[color:var(--color-slate-200)] bg-[color:var(--color-paper)]">
    <div class="container-page py-10 md:py-14">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((s) => (
          <div>
            <div class="font-display text-[2.2rem] md:text-[2.8rem] leading-none text-[color:var(--color-ink)]">{s.value}</div>
            <div class="text-[0.85rem] text-[color:var(--color-slate-600)] mt-2">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Product categories (4) ─── -->
  {productCategories.map((cat, i) => (
    <section class={i % 2 === 0 ? "bg-[color:var(--color-paper)]" : "bg-[color:var(--color-cream)]"}>
      <div class="container-page section-padding">
        <div class="grid lg:grid-cols-[1fr_1.4fr] gap-12 lg:gap-16 items-start">
          <div class="lg:sticky lg:top-24">
            <span class="eyebrow">{cat.eyebrow}</span>
            <h2 class="font-display text-[2rem] md:text-[2.6rem] lg:text-[2.9rem] leading-[1.05] tracking-tight mt-4 text-[color:var(--color-ink)]">
              {cat.title}
            </h2>
            <p class="mt-5 text-[1.05rem] leading-relaxed text-[color:var(--color-slate-600)]">
              {cat.description}
            </p>
            <a href="/contact" class="btn-link mt-6">See it on a demo</a>
          </div>

          <div class="grid gap-3 sm:gap-4">
            {cat.products.map((p) => (
              <article class="card-flat hover:shadow-md hover:border-[color:var(--color-slate-300)] transition-all">
                <div class="flex items-start gap-4">
                  <div class="grid place-items-center w-10 h-10 rounded-xl bg-[color:var(--color-mint)] text-[color:var(--color-accent-dark)] flex-shrink-0 mt-0.5">
                    <span class="text-[1rem] font-bold">✓</span>
                  </div>
                  <div class="flex-1">
                    <h3 class="font-display text-[1.15rem] font-semibold text-[color:var(--color-ink)] leading-snug">{p.name}</h3>
                    <p class="mt-1.5 text-[0.95rem] leading-relaxed text-[color:var(--color-slate-600)]">{p.description}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- ─── Pricing tiers ─── -->
  <section class="bg-[color:var(--color-paper)]">
    <div class="container-page section-padding">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="eyebrow">Pricing</span>
        <h2 class="font-display text-[2.2rem] md:text-[3rem] leading-[1.05] tracking-tight mt-4 text-[color:var(--color-ink)]">
          Three plans. Free website with every one.
        </h2>
        <p class="mt-5 text-[1.05rem] leading-relaxed text-[color:var(--color-slate-600)]">
          Start where you bleed. Move up only when you outgrow it.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5 max-w-6xl mx-auto">
        {tiers.map((tier) => {
          const isPopular = tier.badge === "Most popular";
          const isFlagship = tier.badge === "Flagship";
          return (
            <article class:list={[
              "rounded-2xl p-7 flex flex-col relative",
              isFlagship ? "bg-[color:var(--color-ink)] text-[color:var(--color-paper)]" : "bg-[color:var(--color-paper)] border border-[color:var(--color-slate-200)]",
              isPopular && "ring-2 ring-[color:var(--color-accent)] shadow-[0_20px_40px_-20px_rgb(16_185_129_/_0.35)]",
            ]}>
              {tier.badge && (
                <div class:list={[
                  "absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full text-[0.72rem] font-semibold tracking-wide",
                  isFlagship ? "bg-[color:var(--color-accent)] text-[color:var(--color-ink)]" : "bg-[color:var(--color-accent)] text-[color:var(--color-paper)]",
                ]}>
                  {tier.badge}
                </div>
              )}

              <h3 class={`font-display text-[1.35rem] font-semibold ${isFlagship ? "text-[color:var(--color-paper)]" : "text-[color:var(--color-ink)]"}`}>{tier.name}</h3>
              <p class={`mt-1.5 text-[0.93rem] ${isFlagship ? "text-[color:var(--color-paper)]/70" : "text-[color:var(--color-slate-600)]"}`}>{tier.tagline}</p>

              <div class="mt-6 flex items-baseline gap-1.5">
                <span class={`font-display text-[3rem] leading-none ${isFlagship ? "text-[color:var(--color-accent)]" : "text-[color:var(--color-ink)]"}`}>${tier.price}</span>
                <span class={`text-[0.93rem] ${isFlagship ? "text-[color:var(--color-paper)]/60" : "text-[color:var(--color-slate-500)]"}`}>/ month</span>
              </div>

              <ul class={`mt-6 space-y-3 text-[0.93rem] flex-1 ${isFlagship ? "text-[color:var(--color-paper)]/90" : "text-[color:var(--color-slate-700)]"}`}>
                {tier.features.map((f) => (
                  <li class="flex items-start gap-2.5">
                    <span class={`mt-0.5 grid place-items-center w-5 h-5 rounded-full flex-shrink-0 text-[0.65rem] font-bold ${isFlagship ? "bg-[color:var(--color-accent)]/20 text-[color:var(--color-accent)]" : "bg-[color:var(--color-mint)] text-[color:var(--color-accent-dark)]"}`}>✓</span>
                    <span>{f}</span>
                  </li>
                ))}
              </ul>

              <a
                href="/contact"
                class:list={[
                  "mt-7 inline-flex items-center justify-center gap-2 font-semibold text-[0.95rem] py-3 px-5 rounded-full transition-all",
                  isPopular ? "bg-[color:var(--color-accent)] text-[color:var(--color-paper)] hover:bg-[color:var(--color-accent-dark)]" :
                  isFlagship ? "bg-[color:var(--color-accent)] text-[color:var(--color-ink)] hover:bg-[color:var(--color-accent-dark)] hover:text-[color:var(--color-paper)]" :
                  "bg-[color:var(--color-ink)] text-[color:var(--color-paper)] hover:bg-[color:var(--color-ink-soft)]",
                ]}
              >
                Book a demo →
              </a>
            </article>
          );
        })}
      </div>

      <div class="text-center mt-10">
        <a href="/pricing" class="btn-link">Compare all features</a>
      </div>
    </div>
  </section>

  <!-- ─── Testimonials ─── -->
  <section class="bg-[color:var(--color-cream)]">
    <div class="container-page section-padding">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="eyebrow">What plumbers say</span>
        <h2 class="font-display text-[2.2rem] md:text-[3rem] leading-[1.05] tracking-tight mt-4 text-[color:var(--color-ink)]">
          Real shops. Real numbers.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {testimonials.map((t) => (
          <figure class="card-flat">
            <div class="text-[color:var(--color-warning)] text-[0.95rem] mb-4">★ ★ ★ ★ ★</div>
            <blockquote class="text-[color:var(--color-ink)] text-[1rem] leading-relaxed">
              "{t.quote}"
            </blockquote>
            <figcaption class="mt-5 pt-5 border-t border-[color:var(--color-slate-200)] flex items-center gap-3">
              <div class="grid place-items-center w-10 h-10 rounded-full bg-[color:var(--color-ink)] text-[color:var(--color-accent)] font-display font-semibold text-[0.85rem]">
                {t.initials}
              </div>
              <div>
                <div class="font-semibold text-[color:var(--color-ink)] text-[0.9rem]">{t.name}</div>
                <div class="text-[0.82rem] text-[color:var(--color-slate-500)]">{t.business}</div>
              </div>
            </figcaption>
          </figure>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/case-studies" class="btn-link">Read all 11 case studies</a>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="bg-[color:var(--color-paper)]">
    <div class="container-page section-padding">
      <div class="grid lg:grid-cols-[1fr_1.5fr] gap-12">
        <div>
          <span class="eyebrow">FAQ</span>
          <h2 class="font-display text-[2.2rem] md:text-[2.8rem] leading-[1.05] tracking-tight mt-4 text-[color:var(--color-ink)]">
            Things shop owners ask first.
          </h2>
          <p class="mt-5 text-[1.02rem] leading-relaxed text-[color:var(--color-slate-600)] max-w-sm">
            If your question isn't here, the demo is the right place. We'll answer on the spot.
          </p>
        </div>
        <div class="space-y-3">
          {faqs.map((faq) => (
            <details class="group card-flat hover:border-[color:var(--color-slate-300)] transition-colors">
              <summary class="flex items-start justify-between gap-4 cursor-pointer">
                <span class="font-display font-semibold text-[1.1rem] text-[color:var(--color-ink)] leading-snug">{faq.q}</span>
                <span class="faq-icon grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-slate-100)] text-[color:var(--color-ink)] text-[1rem] font-bold flex-shrink-0">+</span>
              </summary>
              <p class="mt-4 text-[0.97rem] leading-relaxed text-[color:var(--color-slate-600)]">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Bottom CTA ─── -->
  <section class="bg-[color:var(--color-ink)] relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[color:var(--color-accent)]/15 via-transparent to-[color:var(--color-accent)]/5 pointer-events-none"></div>
    <div class="container-page section-padding relative">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-display text-[2.2rem] md:text-[3.2rem] leading-[1.05] tracking-tight text-[color:var(--color-paper)]">
          Ready to stop missing jobs?
        </h2>
        <p class="mt-5 text-[1.1rem] leading-relaxed text-[color:var(--color-paper)]/75 max-w-2xl mx-auto">
          Twenty-minute demo. We pull up your Google Business Profile live and tell you straight whether the system fits.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/contact" class="btn-accent text-[1rem] !py-4 !px-7">
            Book a demo →
          </a>
          <a href="tel:+16265550199" class="inline-flex items-center gap-2 text-[color:var(--color-paper)] text-[1rem] font-medium px-6 py-4 hover:text-[color:var(--color-accent)] transition-colors">
            Or call (626) 555-0199
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
