---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Feature {
  num: string;
  title: string;
  description: string;
  badge?: string;
}

const features: Feature[] = [
  {
    num: "01",
    title: "Missed-call-text-back",
    description: "Every missed call fires an automatic text in under 12 seconds — \"Sorry we missed you, what's the address?\" — so the lead never bounces to your competitor.",
    badge: "Hero offer",
  },
  {
    num: "02",
    title: "Conversion-tested website",
    description: "Mobile-first site rebuilt from scratch with a sticky call button, instant quote form, and the trust signals homeowners look for before they dial.",
  },
  {
    num: "03",
    title: "NAP citation engine",
    description: "Your name, address, and phone synced across 80+ directories so Google trusts you faster and your map pack ranking actually compounds.",
  },
  {
    num: "04",
    title: "Review request automation",
    description: "After every closed job, the system texts a one-tap Google review link. The 5-stars stack up without you nagging the homeowner.",
  },
  {
    num: "05",
    title: "CRM + branded mobile app",
    description: "Pipeline, call history, and texting in one place — plus a white-labeled iOS and Android app so your techs respond from the truck.",
  },
  {
    num: "06",
    title: "Quarterly re-activation campaign",
    description: "Every 90 days we text your past customers with a seasonal offer or maintenance reminder. Repeat work without buying it back from a lead-gen app.",
  },
];

interface ComparisonRow {
  label: string;
  jobsiterank: string;
  leadgen: string;
  agencies: string;
}

const comparisonRows: ComparisonRow[] = [
  {
    label: "Cost structure",
    jobsiterank: "From $197/mo · 3 tiers",
    leadgen: "$25–$150 per lead, per call",
    agencies: "$1.5k–$5k retainers + setup",
  },
  {
    label: "Who owns the leads",
    jobsiterank: "You — phone, texts, reviews",
    leadgen: "The platform — they rent them",
    agencies: "You, but locked behind logins",
  },
  {
    label: "Website included",
    jobsiterank: "Conversion-tested rebuild",
    leadgen: "None — you stay on theirs",
    agencies: "Add-on, $3k–$8k extra",
  },
  {
    label: "Missed-call-text-back",
    jobsiterank: "Built in, fires in seconds",
    leadgen: "Not offered",
    agencies: "Not offered or extra",
  },
  {
    label: "Review automation",
    jobsiterank: "Auto-text after every job",
    leadgen: "Inside the app, not Google",
    agencies: "Manual or upcharged",
  },
  {
    label: "Branded mobile app",
    jobsiterank: "White-labeled iOS + Android",
    leadgen: "Their brand, not yours",
    agencies: "Rare",
  },
  {
    label: "Contract length",
    jobsiterank: "Month-to-month",
    leadgen: "Pay-per-lead, no exit",
    agencies: "12-month minimum",
  },
];

interface FaqItem {
  q: string;
  a: string;
}

const faqs: FaqItem[] = [
  {
    q: "Why three tiers and not one flat price?",
    a: "Because not every shop needs everything. Never Miss a Lead at $197 stops the bleeding for shops that just need to stop missing calls. Lead + Review Engine at $297 adds the review automation that drives map-pack ranking. Local Authority at $497 is the full system — citations, GBP posts, review responses, customer touch. Start where you bleed; move up when you outgrow it.",
  },
  {
    q: "How is this different from HomeAdvisor or Angi?",
    a: "Lead-gen apps rent you a lead, then re-rent it to three of your competitors. We build the channel that you own — your own ranking on Google, your own phone, your own review profile. Cancel us and you keep all of it.",
  },
  {
    q: "Do you work with brand new businesses?",
    a: "Yes. We've launched plumbers from a brand-new LLC with no reviews into the Pasadena map pack inside 90 days. The Local Authority tier is designed for both established shops and fresh entrants.",
  },
  {
    q: "What's the onboarding timeline?",
    a: "Day 1 we lock the demo. Days 2–10 we ship the new site and missed-call-text-back. Days 10–30 we run the citation push and stand up review automation. By day 45 the system is fully live.",
  },
  {
    q: "What does the $597 AI Receptionist add-on do?",
    a: "It's an AI agent that picks up every call you can't — answers in your shop's voice, books appointments straight to your calendar, handles common objections before you ever pick up. Stacks on any of the three tiers. Most shops use it to replace a $4,000+/mo answering service.",
  },
  {
    q: "What trades do you actually serve?",
    a: "Plumbing, HVAC, roofing, and electrical — concentrated in Pasadena, the San Gabriel Valley, and Greater LA. We turn down trades and geographies we don't have a track record in.",
  },
];
---

<BaseLayout title="JobsiteRank — missed the call? we just texted them back in 12 seconds." headerVariant="light">
  <!-- Hero -->
  <section class="dark-section">
    <div class="grain"></div>
    <div class="container-dossier pt-12 pb-24 md:pt-20 md:pb-32 relative">
      <div class="flex items-center gap-4 mb-12">
        <span class="file-tag">File 001</span>
        <span class="meta">Marketing dossier · Edition 01</span>
      </div>

      <div class="grid lg:grid-cols-[1.35fr_1fr] gap-14 items-end">
        <div>
          <span class="inline-flex items-center gap-2 mb-7 font-mono text-[0.7rem] tracking-[0.18em] uppercase text-[color:var(--color-amber)] border border-[color:var(--color-amber)]/40 px-2.5 py-1">
            <span aria-hidden="true">●</span> Hero offer · Missed-call-text-back
          </span>
          <h1 class="font-display text-[2.6rem] md:text-[4.4rem] lg:text-[5.4rem] leading-[0.96] tracking-tight">
            You missed the call.<br />
            <span class="text-[color:var(--color-amber)]">We just texted them back.</span>
          </h1>
          <p class="mt-9 max-w-xl text-[color:var(--color-paper)]/80 text-[1.05rem] md:text-[1.18rem] leading-relaxed">
            Every missed call to your shop fires an automatic text in under 12 seconds — <span class="serif-italic">"sorry I missed you, what's the address?"</span> — before that customer dials the next plumber on the search results.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-4">
            <a href="/contact" class="btn-primary">
              Book a demo
              <span aria-hidden="true">→</span>
            </a>
            <a href="/pricing" class="btn-ghost">From $197/mo · see tiers</a>
          </div>

          <div class="mt-12 grid grid-cols-3 gap-6 max-w-xl">
            <div>
              <div class="font-display text-3xl text-[color:var(--color-amber)]">12s</div>
              <div class="meta mt-1">Auto-text response</div>
            </div>
            <div>
              <div class="font-display text-3xl text-[color:var(--color-amber)]">40%</div>
              <div class="meta mt-1">After-hours rescue rate</div>
            </div>
            <div>
              <div class="font-display text-3xl text-[color:var(--color-amber)]">$387</div>
              <div class="meta mt-1">Avg revenue lost per missed call</div>
            </div>
          </div>
        </div>

        <!-- Live text-thread demo -->
        <aside class="card-warm text-[color:var(--color-ink)] p-5 sm:p-6 relative">
          <div class="flex items-center justify-between mb-4">
            <span class="file-tag">Live demo · 4:23 PM</span>
            <span class="meta">Pasadena, CA</span>
          </div>

          <div class="border border-[color:var(--color-ink)]/15 bg-[color:var(--color-paper)] p-4 space-y-3">
            <!-- Missed call -->
            <div class="flex items-center gap-3 pb-3 border-b border-[color:var(--color-ink)]/10">
              <span class="grid place-items-center w-8 h-8 bg-[color:var(--color-ink)]/8 rounded-full text-[0.85rem]" aria-hidden="true">✆</span>
              <div class="flex-1 min-w-0">
                <div class="font-mono text-[0.72rem] tracking-[0.14em] uppercase text-[color:var(--color-ink)]/60 leading-tight">Missed call · (818) ▓▓▓-0142</div>
                <div class="meta mt-0.5">4:23 PM · No voicemail left</div>
              </div>
            </div>

            <!-- Auto-text out (right) -->
            <div class="flex justify-end">
              <div class="max-w-[85%]">
                <div class="bg-[color:var(--color-amber)] text-[color:var(--color-ink)] px-3 py-2 text-[0.88rem] leading-snug border border-[color:var(--color-ink)]/15">
                  Hey, this is Marco at Plumbing Geeks — sorry I missed your call. What's the address &amp; what's going on?
                </div>
                <div class="meta text-right mt-1">JR auto-text · 4:23 PM</div>
              </div>
            </div>

            <!-- Customer reply (left) -->
            <div class="flex justify-start">
              <div class="max-w-[85%]">
                <div class="bg-[color:var(--color-paper-warm)] text-[color:var(--color-ink)] px-3 py-2 text-[0.88rem] leading-snug border border-[color:var(--color-ink)]/15">
                  1432 Linda Vista. Water heater leaking everywhere. Can you come now??
                </div>
                <div class="meta mt-1">Customer · 4:25 PM</div>
              </div>
            </div>

            <!-- Reply -->
            <div class="flex justify-end">
              <div class="max-w-[85%]">
                <div class="bg-[color:var(--color-amber)] text-[color:var(--color-ink)] px-3 py-2 text-[0.88rem] leading-snug border border-[color:var(--color-ink)]/15">
                  On the way. ETA 35 min. Shut off the water at the wall valve if you can.
                </div>
                <div class="meta text-right mt-1">Marco · 4:26 PM</div>
              </div>
            </div>
          </div>

          <div class="mt-4 pt-4 border-t rule-line flex items-center justify-between">
            <div>
              <div class="font-display text-[0.95rem] font-semibold">Missed call → booked job</div>
              <div class="meta">3 minutes, zero touches from you</div>
            </div>
            <div class="font-mono text-[0.7rem] tracking-[0.18em] text-[color:var(--color-amber-deep)]">
              CASE 002
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="bg-[color:var(--color-paper-warm)] border-y border-[color:var(--color-rule)]">
    <div class="container-dossier py-7 grid md:grid-cols-[auto_1fr] gap-x-10 gap-y-4 items-center">
      <div class="eyebrow">Trusted across the trades</div>
      <div class="flex flex-wrap items-center gap-x-10 gap-y-3 font-display text-[1.05rem] tracking-tight text-[color:var(--color-ink)]/80">
        <span>Plumbing Geeks</span>
        <span class="opacity-30">/</span>
        <span>SGV HVAC Co.</span>
        <span class="opacity-30">/</span>
        <span>Foothill Roofing</span>
        <span class="opacity-30">/</span>
        <span>Arroyo Electric</span>
        <span class="opacity-30">/</span>
        <span>Crown City Drains</span>
        <span class="opacity-30">/</span>
        <span>Westside Sparks</span>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="relative bg-[color:var(--color-paper)]">
    <div class="grain-light"></div>
    <div class="container-dossier py-24 relative">
      <div class="grid lg:grid-cols-[1fr_2fr] gap-12 items-end mb-14">
        <div>
          <span class="file-tag">Section 02</span>
          <h2 class="font-display text-[2.2rem] md:text-[3rem] leading-[1] tracking-tight mt-5">
            One bundle.<br />Six moving parts.
          </h2>
        </div>
        <p class="text-[1.05rem] leading-relaxed text-[color:var(--color-ink)]/75 max-w-xl lg:justify-self-end">
          Everything below is included in the $497 flat monthly. Nothing is a tier you have to graduate into. Nothing is sold as a setup fee.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((feature) => (
          <article class="card-paper p-7 flex flex-col h-full relative">
            {feature.badge && (
              <span class="absolute -top-3 left-6 bg-[color:var(--color-amber)] text-[color:var(--color-ink)] font-mono text-[0.65rem] tracking-[0.18em] uppercase px-2.5 py-1 border border-[color:var(--color-ink)]">
                {feature.badge}
              </span>
            )}
            <div class="flex items-baseline justify-between mb-5">
              <span class="font-mono text-[0.72rem] tracking-[0.18em] text-[color:var(--color-amber-deep)]">F/{feature.num}</span>
              <span class="meta">Included</span>
            </div>
            <h3 class="font-display text-[1.45rem] leading-tight">{feature.title}</h3>
            <p class="mt-3 text-[0.95rem] leading-relaxed text-[color:var(--color-ink)]/75">
              {feature.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="bg-[color:var(--color-paper-warm)] border-y border-[color:var(--color-rule)]">
    <div class="container-dossier py-24">
      <div class="flex items-end justify-between flex-wrap gap-6 mb-10">
        <div>
          <span class="file-tag">Section 03</span>
          <h2 class="font-display text-[2.2rem] md:text-[3rem] leading-[1] tracking-tight mt-5 max-w-2xl">
            How JobsiteRank<br />stacks against the alternatives.
          </h2>
        </div>
        <p class="text-[0.95rem] text-[color:var(--color-ink)]/65 max-w-sm">
          Quick comparison so you know what you're actually buying — and what you're walking away from.
        </p>
      </div>

      <!-- Desktop table -->
      <div class="hidden md:block overflow-x-auto border border-[color:var(--color-ink)] bg-[color:var(--color-paper)]">
        <table class="w-full text-left border-collapse min-w-[720px]">
          <thead>
            <tr class="border-b border-[color:var(--color-ink)] bg-[color:var(--color-ink)] text-[color:var(--color-paper)]">
              <th class="px-5 py-4 font-mono text-[0.72rem] tracking-[0.16em] uppercase font-normal">Capability</th>
              <th class="px-5 py-4 font-mono text-[0.72rem] tracking-[0.16em] uppercase font-normal text-[color:var(--color-amber)]">JobsiteRank</th>
              <th class="px-5 py-4 font-mono text-[0.72rem] tracking-[0.16em] uppercase font-normal">Lead-gen apps</th>
              <th class="px-5 py-4 font-mono text-[0.72rem] tracking-[0.16em] uppercase font-normal">Most agencies</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, idx) => (
              <tr class:list={["border-b border-[color:var(--color-rule)]", idx % 2 === 1 ? "bg-[color:var(--color-paper-warm)]/40" : ""]}>
                <td class="px-5 py-4 font-display text-[1rem] font-semibold align-top">{row.label}</td>
                <td class="px-5 py-4 align-top text-[0.95rem]">
                  <span class="inline-flex gap-2 items-start">
                    <span class="text-[color:var(--color-amber-deep)] mt-0.5">●</span>
                    <span>{row.jobsiterank}</span>
                  </span>
                </td>
                <td class="px-5 py-4 align-top text-[0.95rem] text-[color:var(--color-ink)]/65">{row.leadgen}</td>
                <td class="px-5 py-4 align-top text-[0.95rem] text-[color:var(--color-ink)]/65">{row.agencies}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile stacked cards -->
      <div class="md:hidden space-y-4">
        {comparisonRows.map((row, idx) => (
          <article class="border border-[color:var(--color-ink)] bg-[color:var(--color-paper)]">
            <header class="bg-[color:var(--color-ink)] text-[color:var(--color-paper)] px-4 py-3 flex items-baseline justify-between gap-3">
              <span class="font-display text-[0.98rem] font-semibold leading-snug">{row.label}</span>
              <span class="font-mono text-[0.65rem] tracking-[0.16em] uppercase text-[color:var(--color-paper)]/60 shrink-0">R/{String(idx + 1).padStart(2, "0")}</span>
            </header>
            <dl class="divide-y divide-[color:var(--color-rule)]">
              <div class="px-4 py-3.5">
                <dt class="font-mono text-[0.65rem] tracking-[0.16em] uppercase text-[color:var(--color-amber-deep)] mb-1.5 flex items-center gap-2">
                  <span class="w-1 h-1 rounded-full bg-[color:var(--color-amber-deep)]"></span>
                  JobsiteRank
                </dt>
                <dd class="text-[0.95rem] leading-snug">{row.jobsiterank}</dd>
              </div>
              <div class="px-4 py-3.5">
                <dt class="font-mono text-[0.65rem] tracking-[0.16em] uppercase text-[color:var(--color-ink)]/55 mb-1.5">Lead-gen apps</dt>
                <dd class="text-[0.95rem] leading-snug text-[color:var(--color-ink)]/70">{row.leadgen}</dd>
              </div>
              <div class="px-4 py-3.5">
                <dt class="font-mono text-[0.65rem] tracking-[0.16em] uppercase text-[color:var(--color-ink)]/55 mb-1.5">Most agencies</dt>
                <dd class="text-[0.95rem] leading-snug text-[color:var(--color-ink)]/70">{row.agencies}</dd>
              </div>
            </dl>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing tiers -->
  <section class="dark-section">
    <div class="grain"></div>
    <div class="container-dossier py-24">
      <div class="grid lg:grid-cols-[1fr_1.5fr] gap-12 items-end mb-12">
        <div>
          <span class="file-tag">Section 04</span>
          <h2 class="font-display text-[2.2rem] md:text-[3.2rem] leading-[1] tracking-tight mt-5">
            Three tiers.<br />
            <span class="serif-italic text-[color:var(--color-amber)]">Start where you bleed.</span>
          </h2>
        </div>
        <p class="text-[color:var(--color-paper)]/75 text-[1.02rem] leading-relaxed max-w-xl lg:justify-self-end">
          Start at $197 — never miss a lead. Move up to stack reviews. Top tier owns the local map for you. Every tier ships with the website, so even the entry beats most agencies' setup fee.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <!-- Tier A · Never Miss a Lead -->
        <article class="card-warm text-[color:var(--color-ink)] p-6 flex flex-col relative">
          <div class="absolute -top-3 left-5 bg-[color:var(--color-paper)] text-[color:var(--color-amber-deep)] font-mono text-[0.6rem] tracking-[0.18em] uppercase px-2 py-1 border border-[color:var(--color-ink)]">
            Hero offer
          </div>
          <div class="flex items-center justify-between mb-4 mt-2">
            <span class="font-mono text-[0.7rem] tracking-[0.18em] uppercase text-[color:var(--color-amber-deep)]">Plan A</span>
            <span class="meta">Month-to-month</span>
          </div>
          <div class="font-display text-[1.4rem] leading-tight tracking-tight mb-2">Never Miss a Lead</div>
          <div class="flex items-baseline gap-1.5 mb-4">
            <span class="font-display text-[3rem] leading-none">$197</span>
            <span class="font-mono text-[0.7rem] tracking-[0.16em] uppercase text-[color:var(--color-ink)]/60">/ mo</span>
          </div>
          <ul class="space-y-1.5 text-[0.88rem] mb-5 flex-1">
            <li class="flex gap-2"><span class="text-[color:var(--color-amber-deep)]">→</span> Conversion-tested website</li>
            <li class="flex gap-2"><span class="text-[color:var(--color-amber-deep)]">→</span> Missed-call-text-back</li>
            <li class="flex gap-2"><span class="text-[color:var(--color-amber-deep)]">→</span> SMS inbox + mobile app</li>
            <li class="flex gap-2"><span class="text-[color:var(--color-amber-deep)]">→</span> Basic CRM</li>
          </ul>
          <a href="/contact" class="btn-ghost text-[color:var(--color-ink)] justify-center">Book a demo →</a>
        </article>

        <!-- Tier B · Lead + Review Engine -->
        <article class="card-warm text-[color:var(--color-ink)] p-6 flex flex-col relative border-[color:var(--color-amber)] shadow-[6px_6px_0_0_var(--color-amber)]">
          <div class="absolute -top-3 left-5 bg-[color:var(--color-amber)] text-[color:var(--color-ink)] font-mono text-[0.6rem] tracking-[0.18em] uppercase px-2 py-1 border border-[color:var(--color-ink)]">
            Most popular
          </div>
          <div class="flex items-center justify-between mb-4 mt-2">
            <span class="font-mono text-[0.7rem] tracking-[0.18em] uppercase text-[color:var(--color-amber-deep)]">Plan B</span>
            <span class="meta">Month-to-month</span>
          </div>
          <div class="font-display text-[1.4rem] leading-tight tracking-tight mb-2">Lead + Review Engine</div>
          <div class="flex items-baseline gap-1.5 mb-4">
            <span class="font-display text-[3rem] leading-none">$297</span>
            <span class="font-mono text-[0.7rem] tracking-[0.16em] uppercase text-[color:var(--color-ink)]/60">/ mo</span>
          </div>
          <ul class="space-y-1.5 text-[0.88rem] mb-5 flex-1">
            <li class="flex gap-2"><span class="text-[color:var(--color-amber-deep)]">→</span> Everything in Plan A</li>
            <li class="flex gap-2"><span class="text-[color:var(--color-amber-deep)]">→</span> Review request automation</li>
            <li class="flex gap-2"><span class="text-[color:var(--color-amber-deep)]">→</span> Smart cooldown per customer</li>
            <li class="flex gap-2"><span class="text-[color:var(--color-amber-deep)]">→</span> Monthly review report</li>
          </ul>
          <a href="/contact" class="btn-primary justify-center">Book a demo →</a>
        </article>

        <!-- Tier C · Local Authority -->
        <article class="bg-[color:var(--color-ink)] text-[color:var(--color-paper)] border border-[color:var(--color-amber)] p-6 flex flex-col relative">
          <div class="absolute -top-3 left-5 bg-[color:var(--color-amber)] text-[color:var(--color-ink)] font-mono text-[0.6rem] tracking-[0.18em] uppercase px-2 py-1 border border-[color:var(--color-ink)]">
            Flagship
          </div>
          <div class="flex items-center justify-between mb-4 mt-2">
            <span class="font-mono text-[0.7rem] tracking-[0.18em] uppercase text-[color:var(--color-amber)]">Plan C</span>
            <span class="meta">Month-to-month</span>
          </div>
          <div class="font-display text-[1.4rem] leading-tight tracking-tight mb-2">Local Authority</div>
          <div class="flex items-baseline gap-1.5 mb-4">
            <span class="font-display text-[3rem] leading-none text-[color:var(--color-amber)]">$497</span>
            <span class="font-mono text-[0.7rem] tracking-[0.16em] uppercase text-[color:var(--color-paper)]/60">/ mo</span>
          </div>
          <ul class="space-y-1.5 text-[0.88rem] mb-5 flex-1 text-[color:var(--color-paper)]/90">
            <li class="flex gap-2"><span class="text-[color:var(--color-amber)]">→</span> Everything in Plan B</li>
            <li class="flex gap-2"><span class="text-[color:var(--color-amber)]">→</span> Full CRM (pipeline + history)</li>
            <li class="flex gap-2"><span class="text-[color:var(--color-amber)]">→</span> NAP citations (80+)</li>
            <li class="flex gap-2"><span class="text-[color:var(--color-amber)]">→</span> GBP posts (2×/wk)</li>
            <li class="flex gap-2"><span class="text-[color:var(--color-amber)]">→</span> Review responses</li>
            <li class="flex gap-2"><span class="text-[color:var(--color-amber)]">→</span> Quarterly re-activation campaign</li>
            <li class="flex gap-2"><span class="text-[color:var(--color-amber)]">→</span> Local on-page SEO</li>
          </ul>
          <a href="/contact" class="btn-primary justify-center">Book a demo →</a>
        </article>
      </div>

      <!-- AI Receptionist add-on -->
      <div class="mt-6 border border-[color:var(--color-rule-dark)] p-5 md:p-6 grid md:grid-cols-[1fr_auto] items-center gap-4">
        <div>
