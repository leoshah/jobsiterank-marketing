---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Feature {
  num: string;
  title: string;
  description: string;
  badge?: string;
}

const features: Feature[] = [
  {
    num: "01",
    title: "Missed-call-text-back",
    description: "Every missed call fires an automatic text in under 12 seconds — \"Sorry we missed you, what's the address?\" — so the lead never bounces to your competitor.",
    badge: "Hero offer",
  },
  {
    num: "02",
    title: "Conversion-tested website",
    description: "Mobile-first site rebuilt from scratch with a sticky call button, instant quote form, and the trust signals homeowners look for before they dial.",
  },
  {
    num: "03",
    title: "NAP citation engine",
    description: "Your name, address, and phone synced across 80+ directories so Google trusts you faster and your map pack ranking actually compounds.",
  },
  {
    num: "04",
    title: "Review request automation",
    description: "After every closed job, the system texts a one-tap Google review link. The 5-stars stack up without you nagging the homeowner.",
  },
  {
    num: "05",
    title: "CRM + branded mobile app",
    description: "Pipeline, call history, and texting in one place — plus a white-labeled iOS and Android app so your techs respond from the truck.",
  },
  {
    num: "06",
    title: "Quarterly customer touch",
    description: "Every 90 days we send your past customers a seasonal maintenance reminder. Repeat work without buying it back from a lead-gen app.",
  },
];

interface ComparisonRow {
  label: string;
  jobsiterank: string;
  leadgen: string;
  agencies: string;
}

const comparisonRows: ComparisonRow[] = [
  {
    label: "Cost structure",
    jobsiterank: "$497/mo flat",
    leadgen: "$25–$150 per lead, per call",
    agencies: "$1.5k–$5k retainers + setup",
  },
  {
    label: "Who owns the leads",
    jobsiterank: "You — phone, texts, reviews",
    leadgen: "The platform — they rent them",
    agencies: "You, but locked behind logins",
  },
  {
    label: "Website included",
    jobsiterank: "Conversion-tested rebuild",
    leadgen: "None — you stay on theirs",
    agencies: "Add-on, $3k–$8k extra",
  },
  {
    label: "Missed-call-text-back",
    jobsiterank: "Built in, fires in seconds",
    leadgen: "Not offered",
    agencies: "Not offered or extra",
  },
  {
    label: "Review automation",
    jobsiterank: "Auto-text after every job",
    leadgen: "Inside the app, not Google",
    agencies: "Manual or upcharged",
  },
  {
    label: "Branded mobile app",
    jobsiterank: "White-labeled iOS + Android",
    leadgen: "Their brand, not yours",
    agencies: "Rare",
  },
  {
    label: "Contract length",
    jobsiterank: "Month-to-month",
    leadgen: "Pay-per-lead, no exit",
    agencies: "12-month minimum",
  },
];

interface FaqItem {
  q: string;
  a: string;
}

const faqs: FaqItem[] = [
  {
    q: "Why one flat price instead of tiers?",
    a: "Tiers exist so agencies can sell you the next one. We bundled what a trades business actually needs to own its phone — a website, citations, missed-call-text-back, reviews, CRM, and a customer touch program — into a single price so you stop choosing between line items.",
  },
  {
    q: "How is this different from HomeAdvisor or Angi?",
    a: "Lead-gen apps rent you a lead, then re-rent it to three of your competitors. We build the channel that you own — your own ranking on Google, your own phone, your own review profile. Cancel us and you keep all of it.",
  },
  {
    q: "Do you work with brand new businesses?",
    a: "Yes. We've launched plumbers from a brand-new LLC with no reviews into the Pasadena map pack inside 90 days. The bundle is designed for both established shops and fresh entrants.",
  },
  {
    q: "What's the onboarding timeline?",
    a: "Day 1 we lock the strategy call. Days 2–10 we ship the new site and missed-call-text-back. Days 10–30 we run the citation push and stand up review automation. By day 45 the system is fully live.",
  },
  {
    q: "Is the $497 really all-in?",
    a: "Yes. The only optional add-on is the $97/mo Reputation desk if you want our team writing your review responses and Google Business Profile posts for you. Everything else is included in the base price.",
  },
  {
    q: "What trades do you actually serve?",
    a: "Plumbing, HVAC, roofing, and electrical — concentrated in Pasadena, the San Gabriel Valley, and Greater LA. We turn down trades and geographies we don't have a track record in.",
  },
];
---

<BaseLayout title="JobsiteRank — stop renting leads. Own your phone." headerVariant="light">
  <!-- Hero -->
  <section class="dark-section">
    <div class="grain"></div>
    <div class="container-dossier pt-12 pb-24 md:pt-20 md:pb-32 relative">
      <div class="flex items-center gap-4 mb-12">
        <span class="file-tag">File 001</span>
        <span class="meta">Marketing dossier · Edition 01</span>
      </div>

      <div class="grid lg:grid-cols-[1.4fr_1fr] gap-14 items-end">
        <div>
          <h1 class="font-display text-[2.7rem] md:text-[4.6rem] lg:text-[5.6rem] leading-[0.96] tracking-tight">
            Stop renting<br />leads.
            <span class="text-[color:var(--color-amber)]">Own your phone.</span>
          </h1>
          <p class="mt-9 max-w-xl text-[color:var(--color-paper)]/80 text-[1.05rem] md:text-[1.18rem] leading-relaxed">
            Gives plumbers, HVAC techs, roofers, and electricians a website, citation engine, and missed-call-text-back system that turns Google into your top salesperson — for one flat monthly price.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-4">
            <a href="/contact" class="btn-primary">
              Book the strategy call
              <span aria-hidden="true">→</span>
            </a>
            <a href="/pricing" class="btn-ghost">See what's in the bundle</a>
          </div>

          <div class="mt-12 grid grid-cols-3 gap-6 max-w-xl">
            <div>
              <div class="font-display text-3xl text-[color:var(--color-amber)]">$497</div>
              <div class="meta mt-1">Flat monthly</div>
            </div>
            <div>
              <div class="font-display text-3xl text-[color:var(--color-amber)]">12s</div>
              <div class="meta mt-1">Missed-call response</div>
            </div>
            <div>
              <div class="font-display text-3xl text-[color:var(--color-amber)]">90d</div>
              <div class="meta mt-1">Map-pack lift</div>
            </div>
          </div>
        </div>

        <aside class="card-warm text-[color:var(--color-ink)] p-7 relative">
          <div class="flex items-center justify-between mb-5">
            <span class="file-tag">Field note</span>
            <span class="meta">Pasadena, CA</span>
          </div>
          <p class="serif-italic text-[1.4rem] leading-snug">
            "Three weeks in we stopped paying for HomeAdvisor leads. Phone hasn't quit ringing since."
          </p>
          <div class="mt-6 pt-5 border-t rule-line flex items-center justify-between">
            <div>
              <div class="font-display text-[1rem] font-semibold">Marco D.</div>
              <div class="meta">Owner · Plumbing Geeks</div>
            </div>
            <div class="font-mono text-[0.7rem] tracking-[0.18em] text-[color:var(--color-amber-deep)]">
              CASE 002
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="bg-[color:var(--color-paper-warm)] border-y border-[color:var(--color-rule)]">
    <div class="container-dossier py-7 grid md:grid-cols-[auto_1fr] gap-x-10 gap-y-4 items-center">
      <div class="eyebrow">Trusted across the trades</div>
      <div class="flex flex-wrap items-center gap-x-10 gap-y-3 font-display text-[1.05rem] tracking-tight text-[color:var(--color-ink)]/80">
        <span>Plumbing Geeks</span>
        <span class="opacity-30">/</span>
        <span>SGV HVAC Co.</span>
        <span class="opacity-30">/</span>
        <span>Foothill Roofing</span>
        <span class="opacity-30">/</span>
        <span>Arroyo Electric</span>
        <span class="opacity-30">/</span>
        <span>Crown City Drains</span>
        <span class="opacity-30">/</span>
        <span>Westside Sparks</span>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="relative bg-[color:var(--color-paper)]">
    <div class="grain-light"></div>
    <div class="container-dossier py-24 relative">
      <div class="grid lg:grid-cols-[1fr_2fr] gap-12 items-end mb-14">
        <div>
          <span class="file-tag">Section 02</span>
          <h2 class="font-display text-[2.2rem] md:text-[3rem] leading-[1] tracking-tight mt-5">
            One bundle.<br />Six moving parts.
          </h2>
        </div>
        <p class="text-[1.05rem] leading-relaxed text-[color:var(--color-ink)]/75 max-w-xl lg:justify-self-end">
          Everything below is included in the $497 flat monthly. Nothing is a tier you have to graduate into. Nothing is sold as a setup fee.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((feature) => (
          <article class="card-paper p-7 flex flex-col h-full relative">
            {feature.badge && (
              <span class="absolute -top-3 left-6 bg-[color:var(--color-amber)] text-[color:var(--color-ink)] font-mono text-[0.65rem] tracking-[0.18em] uppercase px-2.5 py-1 border border-[color:var(--color-ink)]">
                {feature.badge}
              </span>
            )}
            <div class="flex items-baseline justify-between mb-5">
              <span class="font-mono text-[0.72rem] tracking-[0.18em] text-[color:var(--color-amber-deep)]">F/{feature.num}</span>
              <span class="meta">Included</span>
            </div>
            <h3 class="font-display text-[1.45rem] leading-tight">{feature.title}</h3>
            <p class="mt-3 text-[0.95rem] leading-relaxed text-[color:var(--color-ink)]/75">
              {feature.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="bg-[color:var(--color-paper-warm)] border-y border-[color:var(--color-rule)]">
    <div class="container-dossier py-24">
      <div class="flex items-end justify-between flex-wrap gap-6 mb-10">
        <div>
          <span class="file-tag">Section 03</span>
          <h2 class="font-display text-[2.2rem] md:text-[3rem] leading-[1] tracking-tight mt-5 max-w-2xl">
            How JobsiteRank<br />stacks against the alternatives.
          </h2>
        </div>
        <p class="text-[0.95rem] text-[color:var(--color-ink)]/65 max-w-sm">
          Quick comparison so you know what you're actually buying — and what you're walking away from.
        </p>
      </div>

      <!-- Desktop table -->
      <div class="hidden md:block overflow-x-auto border border-[color:var(--color-ink)] bg-[color:var(--color-paper)]">
        <table class="w-full text-left border-collapse min-w-[720px]">
          <thead>
            <tr class="border-b border-[color:var(--color-ink)] bg-[color:var(--color-ink)] text-[color:var(--color-paper)]">
              <th class="px-5 py-4 font-mono text-[0.72rem] tracking-[0.16em] uppercase font-normal">Capability</th>
              <th class="px-5 py-4 font-mono text-[0.72rem] tracking-[0.16em] uppercase font-normal text-[color:var(--color-amber)]">JobsiteRank</th>
              <th class="px-5 py-4 font-mono text-[0.72rem] tracking-[0.16em] uppercase font-normal">Lead-gen apps</th>
              <th class="px-5 py-4 font-mono text-[0.72rem] tracking-[0.16em] uppercase font-normal">Most agencies</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, idx) => (
              <tr class:list={["border-b border-[color:var(--color-rule)]", idx % 2 === 1 ? "bg-[color:var(--color-paper-warm)]/40" : ""]}>
                <td class="px-5 py-4 font-display text-[1rem] font-semibold align-top">{row.label}</td>
                <td class="px-5 py-4 align-top text-[0.95rem]">
                  <span class="inline-flex gap-2 items-start">
                    <span class="text-[color:var(--color-amber-deep)] mt-0.5">●</span>
                    <span>{row.jobsiterank}</span>
                  </span>
                </td>
                <td class="px-5 py-4 align-top text-[0.95rem] text-[color:var(--color-ink)]/65">{row.leadgen}</td>
                <td class="px-5 py-4 align-top text-[0.95rem] text-[color:var(--color-ink)]/65">{row.agencies}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile stacked cards -->
      <div class="md:hidden space-y-4">
        {comparisonRows.map((row, idx) => (
          <article class="border border-[color:var(--color-ink)] bg-[color:var(--color-paper)]">
            <header class="bg-[color:var(--color-ink)] text-[color:var(--color-paper)] px-4 py-3 flex items-baseline justify-between gap-3">
              <span class="font-display text-[0.98rem] font-semibold leading-snug">{row.label}</span>
              <span class="font-mono text-[0.65rem] tracking-[0.16em] uppercase text-[color:var(--color-paper)]/60 shrink-0">R/{String(idx + 1).padStart(2, "0")}</span>
            </header>
            <dl class="divide-y divide-[color:var(--color-rule)]">
              <div class="px-4 py-3.5">
                <dt class="font-mono text-[0.65rem] tracking-[0.16em] uppercase text-[color:var(--color-amber-deep)] mb-1.5 flex items-center gap-2">
                  <span class="w-1 h-1 rounded-full bg-[color:var(--color-amber-deep)]"></span>
                  JobsiteRank
                </dt>
                <dd class="text-[0.95rem] leading-snug">{row.jobsiterank}</dd>
              </div>
              <div class="px-4 py-3.5">
                <dt class="font-mono text-[0.65rem] tracking-[0.16em] uppercase text-[color:var(--color-ink)]/55 mb-1.5">Lead-gen apps</dt>
                <dd class="text-[0.95rem] leading-snug text-[color:var(--color-ink)]/70">{row.leadgen}</dd>
              </div>
              <div class="px-4 py-3.5">
                <dt class="font-mono text-[0.65rem] tracking-[0.16em] uppercase text-[color:var(--color-ink)]/55 mb-1.5">Most agencies</dt>
                <dd class="text-[0.95rem] leading-snug text-[color:var(--color-ink)]/70">{row.agencies}</dd>
              </div>
            </dl>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing card -->
  <section class="dark-section">
    <div class="grain"></div>
    <div class="container-dossier py-24 grid lg:grid-cols-[1fr_1.1fr] gap-14 items-center">
      <div>
        <span class="file-tag">Section 04</span>
        <h2 class="font-display text-[2.2rem] md:text-[3.2rem] leading-[1] tracking-tight mt-5">
          One price.<br />
          <span class="serif-italic text-[color:var(--color-amber)]">No hidden tiers.</span>
        </h2>
        <p class="mt-7 text-[color:var(--color-paper)]/75 text-[1.05rem] leading-relaxed max-w-md">
          The $497 covers the whole bundle. The $97 add-on exists for shops that want our team responding to reviews and posting to Google Business Profile on their behalf.
        </p>
        <a href="/pricing" class="mt-8 inline-flex btn-ghost border-[color:var(--color-paper)]/40">
          See the full breakdown
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="card-warm text-[color:var(--color-ink)] p-8 relative">
        <div class="absolute -top-3 -right-3 bg-[color:var(--color-amber)] text-[color:var(--color-ink)] font-mono text-[0.65rem] tracking-[0.18em] uppercase px-2.5 py-1 border border-[color:var(--color-ink)]">
          Flat price
        </div>
        <div class="flex items-baseline justify-between mb-6">
          <span class="file-tag">Plan A · Bundle</span>
          <span class="meta">Month-to-month</span>
        </div>
        <div class="flex items-baseline gap-2">
          <span class="font-display text-[3.6rem] leading-none">$497</span>
          <span class="font-mono text-[0.78rem] tracking-[0.16em] uppercase text-[color:var(--color-ink)]/65">/ month, all in</span>
        </div>
        <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1.5 font-mono text-[0.62rem] tracking-[0.16em] uppercase text-[color:var(--color-amber-deep)]">
          <span class="inline-flex items-center gap-1.5"><span aria-hidden="true">✓</span>Cancel anytime</span>
          <span class="opacity-30">·</span>
          <span class="inline-flex items-center gap-1.5"><span aria-hidden="true">✓</span>Month-to-month</span>
          <span class="opacity-30">·</span>
          <span class="inline-flex items-center gap-1.5"><span aria-hidden="true">✓</span>No setup fee</span>
        </div>
        <ul class="mt-6 space-y-2.5 text-[0.95rem]">
          <li class="flex gap-3"><span class="text-[color:var(--color-amber-deep)]">→</span> Conversion-tested website rebuild</li>
          <li class="flex gap-3"><span class="text-[color:var(--color-amber-deep)]">→</span> Missed-call-text-back across every line</li>
          <li class="flex gap-3"><span class="text-[color:var(--color-amber-deep)]">→</span> NAP citation engine, 80+ directories</li>
          <li class="flex gap-3"><span class="text-[color:var(--color-amber-deep)]">→</span> Review request automation</li>
          <li class="flex gap-3"><span class="text-[color:var(--color-amber-deep)]">→</span> CRM + white-labeled iOS &amp; Android app</li>
          <li class="flex gap-3"><span class="text-[color:var(--color-amber-deep)]">→</span> Quarterly customer touch program</li>
        </ul>

        <div class="mt-7 pt-6 border-t border-[color:var(--color-ink)]/20">
          <div class="flex items-baseline justify-between">
            <div>
              <div class="font-display text-[1.05rem] font-semibold">+ Reputation desk</div>
              <div class="meta">Optional · review responses + GBP posts</div>
            </div>
            <div class="font-display text-[1.4rem]">$97<span class="font-mono text-[0.72rem] tracking-[0.16em] uppercase text-[color:var(--color-ink)]/60"> / mo</span></div>
          </div>
        </div>

        <a href="/contact" class="mt-8 btn-primary w-full justify-center">
          Book the strategy call
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Case study -->
  <section class="bg-[color:var(--color-paper)] relative">
    <div class="grain-light"></div>
    <div class="container-dossier py-24 relative">
      <div class="grid lg:grid-cols-[1fr_1.4fr] gap-12">
        <div>
          <span class="file-tag">Case file 002</span>
          <h2 class="font-display text-[2.2rem] md:text-[3rem] leading-[1] tracking-tight mt-5">
            Plumbing Geeks,<br />Pasadena.
          </h2>
          <p class="mt-6 text-[1rem] leading-relaxed text-[color:var(--color-ink)]/75 max-w-md">
            Residential and commercial plumbing shop fighting for map-pack visibility against four older incumbents. We rebuilt the site, wired up missed-call-text-back, and ran the citation push.
          </p>
          <a href="/case-studies" class="mt-7 inline-flex btn-ghost text-[color:var(--color-ink)]">
            Read the full file
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="card-paper p-8 lg:p-10">
          <div class="flex items-center justify-between mb-6">
            <span class="file-tag">Engagement · 6 months</span>
            <span class="meta">Pasadena, CA</span>
          </div>

          <div class="grid sm:grid-cols-3 gap-6 mb-8">
            <div>
              <div class="font-display text-[2.4rem] text-[color:var(--color-amber-deep)] leading-none">3.4×</div>
              <div class="meta mt-2">Inbound calls / mo</div>
            </div>
            <div>
              <div class="font-display text-[2.4rem] text-[color:var(--color-amber-deep)] leading-none">#1</div>
              <div class="meta mt-2">Map pack, "plumber pasadena"</div>
            </div>
            <div>
              <div class="font-display text-[2.4rem] text-[color:var(--color-amber-deep)] leading-none">$0</div>
              <div class="meta mt-2">Spent on lead-gen apps</div>
            </div>
          </div>

          <p class="serif-italic text-[1.25rem] leading-snug border-l-2 border-[color:var(--color-amber)] pl-5">
            "Before JobsiteRank we were spending $2,400 a month renting calls. Now the calls come in on our number, our reviews are stacking up, and the techs love the app."
          </p>
          <div class="mt-5 meta">— Marco D., owner · Plumbing Geeks</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-[color:var(--color-paper-warm)] border-y border-[color:var(--color-rule)]">
    <div class="container-dossier py-24">
      <div class="grid lg:grid-cols-[1fr_2fr] gap-12">
        <div>
          <span class="file-tag">Section 06</span>
          <h2 class="font-display text-[2.2rem] md:text-[3rem] leading-[1] tracking-tight mt-5">
            Things shop<br />owners ask first.
          </h2>
          <p class="mt-5 text-[0.95rem] text-[color:var(--color-ink)]/70 max-w-sm">
            If your question isn't here, the strategy call is the right place — we'll answer it on the spot.
          </p>
        </div>

        <div class="border-t border-[color:var(--color-ink)]">
          {faqs.map((faq, idx) => (
            <details class="group border-b border-[color:var(--color-ink)]">
              <summary class="flex items-center justify-between gap-6 py-5 hover:bg-[color:var(--color-paper)]/50 px-1">
                <div class="flex items-center gap-5 min-w-0">
                  <span class="font-mono text-[0.72rem] tracking-[0.16em] text-[color:var(--color-amber-deep)] shrink-0">Q/{String(idx + 1).padStart(2, "0")}</span>
                  <span class="font-display text-[1.1rem] md:text-[1.2rem] font-semibold leading-snug">{faq.q}</span>
                </div>
                <span class="faq-plus shrink-0 text-[color:var(--color-amber-deep)]"></span>
              </summary>
              <div class="pb-6 px-1 pl-[calc(0.72rem+5rem)] text-[0.97rem] leading-relaxed text-[color:var(--color-ink)]/80">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="dark-section">
    <div class="grain"></div>
    <div class="container-dossier py-24 grid lg:grid-cols-[1.4fr_1fr] gap-12 items-center">
      <div>
        <span class="file-tag">End of file 001</span>
        <h2 class="font-display text-[2.4rem] md:text-[3.6rem] leading-[1] tracking-tight mt-6">
          Ready to stop renting<br />and start owning?
        </h2>
        <p class="mt-6 max-w-xl text-[color:var(--color-paper)]/75 text-[1.05rem] leading-relaxed">
          Twenty-minute call. No deck. We'll look at your current Google Business Profile, your missed-call rate, and tell you straight whether the bundle would move the needle.
        </p>
        <div class="mt-6 flex flex-wrap gap-x-3 gap-y-1.5 font-mono text-[0.65rem] tracking-[0.16em] uppercase text-[color:var(--color-amber)]">
          <span class="inline-flex items-center gap-1.5"><span aria-hidden="true">✓</span>Cancel anytime</span>
          <span class="opacity-30">·</span>
          <span class="inline-flex items-center gap-1.5"><span aria-hidden="true">✓</span>Month-to-month</span>
          <span class="opacity-30">·</span>
          <span class="inline-flex items-center gap-1.5"><span aria-hidden="true">✓</span>No setup fee</span>
        </div>
      </div>
      <div class="flex flex-col gap-4 lg:items-end">
        <a href="/contact" class="btn-primary">
