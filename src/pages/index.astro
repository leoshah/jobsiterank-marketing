  .hero-anim-2 { animation: hero-step 12s ease-out 1.4s infinite; }
  .hero-anim-3 { animation: hero-step 12s ease-out 3.0s infinite; }
  .hero-anim-4 { animation: hero-step 12s ease-out 4.4s infinite; }
  .hero-anim-5 { animation: hero-step 12s ease-out 5.8s infinite; }

  @keyframes hero-step {
    0%   { opacity: 0; transform: translateY(8px); }
    4%   { opacity: 1; transform: translateY(0); }
    /* hold most of the cycle */
    92%  { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(8px); }
  }

  /* ─── Showcase panel · text-back loop (10s) ─── */
