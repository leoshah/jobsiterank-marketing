</style>

<script is:inline>
  (function () {
    const tabs = Array.from(document.querySelectorAll(".showcase-tab"));
    const panels = Array.from(document.querySelectorAll(".showcase-panel"));
    if (!tabs.length || !panels.length) return;

    let autoIndex = 0;
    let autoTimer = null;
    let userInteracted = false;

    function activate(tabKey) {
      tabs.forEach((t) => {
        const active = t.getAttribute("data-tab") === tabKey;
        t.setAttribute("aria-selected", active ? "true" : "false");
      });
      panels.forEach((p) => {
        const active = p.getAttribute("data-panel") === tabKey;
        if (active) {
          p.classList.remove("hidden");
        } else {
          p.classList.add("hidden");
        }
      });
    }

    function rotate() {
      if (userInteracted) return;
      autoIndex = (autoIndex + 1) % tabs.length;
      const key = tabs[autoIndex].getAttribute("data-tab");
      if (key) activate(key);
    }

    tabs.forEach((t, i) => {
      t.addEventListener("click", function () {
        userInteracted = true;
        if (autoTimer) {
          clearInterval(autoTimer);
          autoTimer = null;
        }
        autoIndex = i;
        const key = t.getAttribute("data-tab");
        if (key) activate(key);
      });
    });

    autoTimer = setInterval(rotate, 8000);
  })();
</script>
