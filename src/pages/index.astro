  .panel-reviews .r-anim-1 .r-star:nth-child(2) { animation-delay: 0.75s; }
  .panel-reviews .r-anim-1 .r-star:nth-child(3) { animation-delay: 0.9s; }
  .panel-reviews .r-anim-1 .r-star:nth-child(4) { animation-delay: 1.05s; }
  .panel-reviews .r-anim-1 .r-star:nth-child(5) { animation-delay: 1.2s; }
  .panel-reviews .r-anim-2 .r-star:nth-child(1) { animation-delay: 2.1s; }
  .panel-reviews .r-anim-2 .r-star:nth-child(2) { animation-delay: 2.25s; }
  .panel-reviews .r-anim-2 .r-star:nth-child(3) { animation-delay: 2.4s; }
  .panel-reviews .r-anim-2 .r-star:nth-child(4) { animation-delay: 2.55s; }
  .panel-reviews .r-anim-2 .r-star:nth-child(5) { animation-delay: 2.7s; }

  @keyframes star-pop {
    0%, 5% { transform: scale(0.4); opacity: 0.4; }
    8%     { transform: scale(1.25); opacity: 1; }
    11%    { transform: scale(1); opacity: 1; }
