    opacity: 0;
    transform: translateY(8px);
  }
  .t-anim-1 { animation: panel-step 10s ease-out 0.3s infinite; }
  .t-anim-2 { animation: panel-step 10s ease-out 1.6s infinite; }
  .t-anim-3 { animation: panel-step 10s ease-out 3.2s infinite; }
  .t-anim-4 { animation: panel-step 10s ease-out 4.8s infinite; }
  .t-anim-5 { animation: panel-step 10s ease-out 6.2s infinite; }

  @keyframes panel-step {
    0%   { opacity: 0; transform: translateY(8px); }
    5%   { opacity: 1; transform: translateY(0); }
    90%  { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(8px); }
  }

  /* ─── Reviews panel loop (10s) ─── */
  .r-anim-1, .r-anim-2, .r-anim-3, .r-anim-4 {
    opacity: 0;
    transform: translateX(-8px);
  }
  .r-anim-1 { animation: review-step 10s ease-out 0.3s infinite; }
  .r-anim-2 { animation: review-step 10s ease-out 1.8s infinite; }
  .r-anim-3 { animation: review-step 10s ease-out 3.4s infinite; }
  .r-anim-4 { animation: review-step 10s ease-out 5.2s infinite; }

  @keyframes review-step {
    0%   { opacity: 0; transform: translateX(-8px); }
