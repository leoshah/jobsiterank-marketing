---
import BaseLayout from "../layouts/BaseLayout.astro";

interface FaqItem {
  q: string;
  a: string;
}

const faqs: FaqItem[] = [
  {
    q: "How fast does the missed-call text-back fire?",
    a: "Under 30 seconds, every time. The customer gets an SMS from your business number with a friendly 'sorry I missed you, what's the address?' so the conversation starts before they dial the next plumber.",
  },
  {
    q: "Do I get to keep my phone number?",
    a: "Yes. Port your existing business number or pick a new one — either way it stays yours forever. Cancel us, you keep the number.",
  },
  {
    q: "What's the difference between the two plans?",
    a: "Never Miss a Lead ($297) is the entry plan — free website, missed-call text-back, dedicated business number, mobile messaging, plus full review automation and smart routing. Local Authority ($497) is the full system — adds Google Business Profile optimization & weekly posts, online directory listings (Yelp, Apple Maps, Bing & more), review responses by our team, full branded CRM with lead pipeline, local SEO, and quarterly re-activation campaigns. Start with $297; upgrade when you outgrow it.",
  },
  {
    q: "Is the website really free with every tier?",
    a: "Yes. Both plans ship with a free conversion-focused mobile-first website. No setup fee. The site is built to drive phone calls, not just traffic.",
  },
  {
    q: "How is this different from HomeAdvisor or Angi?",
    a: "Lead-gen apps rent you a lead, then re-rent it to three of your competitors. We build the channel that you own — your own ranking on Google, your own phone, your own review profile. Cancel us and you keep all of it.",
  },
  {
    q: "What trades do you serve?",
    a: "Plumbing, all sub-specialties — residential, commercial, drain & sewer, emergency, tankless, re-pipe. We work with shops across the US.",
  },
];

const stats = [
  { value: "100+", label: "Plumbing shops served" },
  { value: "12s", label: "Avg auto-text response" },
  { value: "4.9★", label: "Average customer rating" },
  { value: "$0", label: "Setup fee, every tier" },
];

const tiers = [
  {
    name: "Never Miss a Lead",
    price: 297,
    tagline: "Catch every missed call. Stack every review.",
    features: [
      "Free conversion-focused website",
      "Missed-call text-back (under 30s)",
      "Dedicated business number",
      "Two-way SMS inbox + mobile messaging app",
      "Weekly missed-call recovery report",
      "Review request automation",
      "Smart routing (happy → Google)",
      "Smart cooldown per customer",
      "Monthly review-volume report",
    ],
    badge: null,
  },
  {
    name: "Local Authority",
    price: 497,
    tagline: "The full system. We own the local map.",
    features: [
      "Everything in Never Miss a Lead",
      "Google My Business optimization",
      "Google Business Profile posts (2×/wk)",
      "Online directory listings (Yelp, Apple Maps, Bing & more)",
      "Review responses by our team",
      "Full CRM with lead pipeline",
      "Full branded mobile CRM",
      "Quarterly re-activation campaigns",
    ],
    badge: "Flagship",
  },
];

const testimonials = [
  {
    quote: "Solo plumber, allergic to having an office. The text-back is basically a dispatcher I don't have to manage. Booked twice the work this year.",
    name: "Mike T.",
    business: "Bluebonnet Plumbing · Austin, TX",
    initials: "MT",
  },
  {
    quote: "We were losing $40k a winter to voicemail and didn't even know it. The text-back caught all of it.",
    name: "Karen M.",
    business: "Mile-High Pipeworks · Denver, CO",
    initials: "KM",
  },
  {
    quote: "Texted 1,800 dormant customers. Booked 87 jobs in two weeks. Best $71k week we've ever had.",
    name: "Diego L.",
    business: "Saguaro Plumbing · Phoenix, AZ",
    initials: "DL",
  },
];
---

<BaseLayout title="JobsiteRank — never miss a lead again">
  <!-- ─── Hero ─── -->
  <section class="bg-[color:var(--color-cream)] relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[color:var(--color-mint)]/40 via-transparent to-transparent pointer-events-none"></div>
    <div class="container-page relative section-padding-tight md:!pt-20 md:!pb-24">
      <div class="grid lg:grid-cols-[1.15fr_1fr] gap-12 lg:gap-16 items-center">
        <div>
          <span class="eyebrow-mint">★ Built for plumbers</span>
          <h1 class="font-display text-[2.4rem] sm:text-[3.2rem] md:text-[3.8rem] lg:text-[4.2rem] leading-[1.02] tracking-tight mt-6 text-[color:var(--color-ink)]">
            Stop losing jobs to voicemail.
            <span class="block mt-2 text-[color:var(--color-accent-dark)]">Get found, get called, get booked.</span>
          </h1>
          <p class="mt-6 max-w-xl text-[1.1rem] md:text-[1.18rem] leading-relaxed text-[color:var(--color-slate-600)]">
            JobsiteRank gives plumbers a conversion-focused website, missed-call text-back, review automation, and a real lead pipeline — all in one stack, starting at <strong class="text-[color:var(--color-ink)]">$297/month</strong>.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a href="/contact" class="btn-accent text-[1rem] !py-4 !px-7">
              Book a demo →
            </a>
            <a href="/pricing" class="btn-outline text-[1rem] !py-4 !px-7">
              See pricing
            </a>
          </div>

          <div class="mt-8 flex items-center gap-3 text-[color:var(--color-slate-500)] text-[0.9rem]">
            <span class="text-[color:var(--color-warning)] text-[1rem]">★ ★ ★ ★ ★</span>
            <span>4.9 across 100+ plumbing shops</span>
            <span class="hidden sm:inline">·</span>
            <span class="hidden sm:inline">Cancel anytime</span>
          </div>
        </div>

        <!-- Phone mockup with text thread -->
        <div class="relative">
          <div class="absolute -inset-4 md:-inset-8 bg-gradient-to-br from-[color:var(--color-accent-soft)] to-transparent rounded-[3rem] blur-2xl pointer-events-none"></div>
          <div class="relative mx-auto max-w-sm bg-[color:var(--color-ink)] rounded-[2.5rem] p-3 shadow-xl">
            <div class="bg-[color:var(--color-paper)] rounded-[2rem] p-5 min-h-[460px]">
              <div class="flex items-center justify-between mb-4 pb-3 border-b border-[color:var(--color-slate-200)]">
                <div class="flex items-center gap-2.5">
                  <span class="grid place-items-center w-8 h-8 rounded-full bg-[color:var(--color-mint)] text-[color:var(--color-accent-dark)] text-[0.85rem]">✆</span>
                  <div>
                    <div class="text-[0.78rem] font-semibold text-[color:var(--color-ink)]">JobsiteRank</div>
                    <div class="text-[0.7rem] text-[color:var(--color-slate-500)]">Live · Pasadena, CA</div>
                  </div>
                </div>
                <span class="text-[0.7rem] text-[color:var(--color-slate-400)]">4:23 PM</span>
              </div>

              <div class="hero-anim-1 bg-[color:var(--color-slate-50)] rounded-xl p-3 mb-3 flex items-center gap-2.5">
                <span class="text-[color:var(--color-slate-400)] text-[1rem]">✆</span>
                <div class="flex-1">
                  <div class="text-[0.78rem] font-medium text-[color:var(--color-ink)]">Missed call · (818) ▓▓▓-0142</div>
                  <div class="text-[0.7rem] text-[color:var(--color-slate-500)]">No voicemail · 4:23 PM</div>
                </div>
              </div>

              <div class="space-y-3">
                <div class="hero-anim-2 flex justify-end">
                  <div class="max-w-[85%]">
                    <div class="bg-[color:var(--color-accent)] text-[color:var(--color-paper)] px-3.5 py-2.5 rounded-2xl rounded-br-md text-[0.85rem] leading-snug">
                      Hey, this is Mile-High Pipeworks — sorry I missed your call. What's the address &amp; what's going on?
                    </div>
                    <div class="text-[0.65rem] text-[color:var(--color-slate-400)] text-right mt-1">Auto-text · 4:23 PM</div>
                  </div>
                </div>

                <div class="hero-anim-3 flex justify-start">
                  <div class="max-w-[85%]">
                    <div class="bg-[color:var(--color-slate-100)] text-[color:var(--color-ink)] px-3.5 py-2.5 rounded-2xl rounded-bl-md text-[0.85rem] leading-snug">
                      1432 Linda Vista. Water heater leaking everywhere. Can you come now??
                    </div>
                    <div class="text-[0.65rem] text-[color:var(--color-slate-400)] mt-1">Customer · 4:25 PM</div>
                  </div>
                </div>

                <div class="hero-anim-4 flex justify-end">
                  <div class="max-w-[85%]">
                    <div class="bg-[color:var(--color-accent)] text-[color:var(--color-paper)] px-3.5 py-2.5 rounded-2xl rounded-br-md text-[0.85rem] leading-snug">
                      On the way. ETA 35 min. Shut off the water at the wall valve if you can.
                    </div>
                    <div class="text-[0.65rem] text-[color:var(--color-slate-400)] text-right mt-1">Karen · 4:26 PM</div>
                  </div>
                </div>
              </div>

              <div class="hero-anim-5 mt-5 pt-4 border-t border-[color:var(--color-slate-200)] flex items-center justify-between">
                <div>
                  <div class="text-[0.85rem] font-semibold text-[color:var(--color-ink)]">Job booked in 3 min</div>
                  <div class="text-[0.7rem] text-[color:var(--color-slate-500)]">Zero touches from you</div>
                </div>
                <span class="tag-pill tag-pill-accent text-[0.68rem]">+$1,840 job</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Trust bar / stats ─── -->
  <section class="border-y border-[color:var(--color-slate-200)] bg-[color:var(--color-paper)]">
    <div class="container-page py-10 md:py-14">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((s) => (
          <div>
            <div class="font-display text-[2.2rem] md:text-[2.8rem] leading-none text-[color:var(--color-ink)]">{s.value}</div>
            <div class="text-[0.85rem] text-[color:var(--color-slate-600)] mt-2">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- ═══ CANDIDATE SECTION 2 · CRM DASHBOARD MOCKUP ═══════════════════════ -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[color:var(--color-paper)]">
    <div class="container-page section-padding">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="font-display text-[2.2rem] md:text-[3rem] lg:text-[3.4rem] leading-[1.05] tracking-tight text-[color:var(--color-ink)]">
          Every lead, every text, every job — in one place.
        </h2>
        <p class="mt-5 text-[1.05rem] leading-relaxed text-[color:var(--color-slate-600)] max-w-2xl mx-auto">
          The Local Authority CRM consolidates calls, texts, and jobs into a real pipeline. Branded to your shop, accessible from your phone.
        </p>
      </div>

      <!-- CRM mockup card -->
      <div class="max-w-6xl mx-auto relative">
        <div class="absolute -inset-4 md:-inset-12 bg-gradient-to-br from-[color:var(--color-accent-soft)] via-transparent to-transparent rounded-[3rem] blur-3xl pointer-events-none"></div>
        <div class="relative rounded-2xl border border-[color:var(--color-slate-200)] bg-[color:var(--color-paper)] shadow-2xl overflow-hidden">
          <!-- Top bar -->
          <div class="flex items-center justify-between px-5 py-3 border-b border-[color:var(--color-slate-200)] bg-[color:var(--color-cream)]">
            <div class="flex items-center gap-3">
              <span class="grid place-items-center w-7 h-7 rounded-lg bg-[color:var(--color-ink)] text-[color:var(--color-accent)] font-display text-[0.78rem] font-bold">MH</span>
              <div>
                <div class="text-[0.85rem] font-semibold text-[color:var(--color-ink)]">Mile-High Pipeworks · Pipeline</div>
                <div class="text-[0.7rem] text-[color:var(--color-slate-500)]">Tuesday · April 14</div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-mint)] text-[color:var(--color-accent-dark)] text-[0.78rem]">●</span>
              <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-slate-100)] text-[color:var(--color-slate-500)] text-[0.78rem]">⌕</span>
              <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-ink)] text-[color:var(--color-paper)] text-[0.7rem] font-semibold">KM</span>
            </div>
          </div>

          <!-- KPI strip -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-[color:var(--color-slate-200)] border-b border-[color:var(--color-slate-200)]">
            <div class="bg-[color:var(--color-paper)] p-4">
              <div class="text-[0.7rem] uppercase tracking-wide text-[color:var(--color-slate-500)] font-semibold">Jobs today</div>
              <div class="font-display text-[1.5rem] font-semibold text-[color:var(--color-ink)] mt-1">14</div>
              <div class="text-[0.72rem] text-[color:var(--color-accent-dark)] font-medium mt-0.5">↑ 3 vs avg</div>
            </div>
            <div class="bg-[color:var(--color-paper)] p-4">
              <div class="text-[0.7rem] uppercase tracking-wide text-[color:var(--color-slate-500)] font-semibold">Calls captured</div>
              <div class="font-display text-[1.5rem] font-semibold text-[color:var(--color-ink)] mt-1">28</div>
              <div class="text-[0.72rem] text-[color:var(--color-accent-dark)] font-medium mt-0.5">21 via text-back</div>
            </div>
            <div class="bg-[color:var(--color-paper)] p-4">
              <div class="text-[0.7rem] uppercase tracking-wide text-[color:var(--color-slate-500)] font-semibold">New reviews</div>
              <div class="font-display text-[1.5rem] font-semibold text-[color:var(--color-ink)] mt-1">+5</div>
              <div class="text-[0.72rem] text-[color:var(--color-warning)] font-medium mt-0.5">★ all 5-star</div>
            </div>
            <div class="bg-[color:var(--color-paper)] p-4">
              <div class="text-[0.7rem] uppercase tracking-wide text-[color:var(--color-slate-500)] font-semibold">Booked revenue</div>
              <div class="font-display text-[1.5rem] font-semibold text-[color:var(--color-ink)] mt-1">$8.2k</div>
              <div class="text-[0.72rem] text-[color:var(--color-accent-dark)] font-medium mt-0.5">today</div>
            </div>
          </div>

          <!-- Pipeline + activity -->
          <div class="grid lg:grid-cols-[2fr_1fr]">
            <!-- Pipeline columns -->
            <div class="p-5 grid grid-cols-2 md:grid-cols-4 gap-3 bg-[color:var(--color-cream)]/40">
              <!-- New leads -->
              <div>
                <div class="flex items-center justify-between mb-3">
                  <span class="text-[0.72rem] font-bold uppercase tracking-wide text-[color:var(--color-slate-600)]">New</span>
                  <span class="text-[0.7rem] font-semibold text-[color:var(--color-slate-500)] bg-[color:var(--color-paper)] px-2 py-0.5 rounded-full">7</span>
                </div>
                <div class="space-y-2">
                  <div class="bg-[color:var(--color-paper)] rounded-lg p-2.5 border border-[color:var(--color-slate-200)]">
                    <div class="text-[0.78rem] font-semibold text-[color:var(--color-ink)] truncate">A. Patel</div>
                    <div class="text-[0.68rem] text-[color:var(--color-slate-500)] mt-0.5 truncate">Water heater leak</div>
                    <div class="text-[0.62rem] text-[color:var(--color-accent-dark)] mt-1 font-medium">Auto-text sent</div>
                  </div>
                  <div class="bg-[color:var(--color-paper)] rounded-lg p-2.5 border border-[color:var(--color-slate-200)]">
                    <div class="text-[0.78rem] font-semibold text-[color:var(--color-ink)] truncate">M. Soriano</div>
                    <div class="text-[0.68rem] text-[color:var(--color-slate-500)] mt-0.5 truncate">Drain backup</div>
                    <div class="text-[0.62rem] text-[color:var(--color-accent-dark)] mt-1 font-medium">Replied · 2m ago</div>
                  </div>
                </div>
              </div>
              <!-- Quoted -->
              <div>
                <div class="flex items-center justify-between mb-3">
                  <span class="text-[0.72rem] font-bold uppercase tracking-wide text-[color:var(--color-slate-600)]">Quoted</span>
                  <span class="text-[0.7rem] font-semibold text-[color:var(--color-slate-500)] bg-[color:var(--color-paper)] px-2 py-0.5 rounded-full">4</span>
                </div>
                <div class="space-y-2">
                  <div class="bg-[color:var(--color-paper)] rounded-lg p-2.5 border border-[color:var(--color-slate-200)]">
                    <div class="text-[0.78rem] font-semibold text-[color:var(--color-ink)] truncate">L. Hernández</div>
                    <div class="text-[0.68rem] text-[color:var(--color-slate-500)] mt-0.5 truncate">Re-pipe estimate</div>
                    <div class="text-[0.62rem] text-[color:var(--color-ink)] mt-1 font-medium">$7,400</div>
                  </div>
                </div>
              </div>
              <!-- Scheduled -->
              <div>
                <div class="flex items-center justify-between mb-3">
                  <span class="text-[0.72rem] font-bold uppercase tracking-wide text-[color:var(--color-slate-600)]">Scheduled</span>
                  <span class="text-[0.7rem] font-semibold text-[color:var(--color-slate-500)] bg-[color:var(--color-paper)] px-2 py-0.5 rounded-full">9</span>
                </div>
                <div class="space-y-2">
                  <div class="bg-[color:var(--color-paper)] rounded-lg p-2.5 border border-[color:var(--color-slate-200)]">
                    <div class="text-[0.78rem] font-semibold text-[color:var(--color-ink)] truncate">D. Wong</div>
                    <div class="text-[0.68rem] text-[color:var(--color-slate-500)] mt-0.5 truncate">Today · 2:00 PM</div>
                    <div class="text-[0.62rem] text-[color:var(--color-ink)] mt-1 font-medium">Tankless install</div>
                  </div>
                  <div class="bg-[color:var(--color-paper)] rounded-lg p-2.5 border border-[color:var(--color-slate-200)]">
                    <div class="text-[0.78rem] font-semibold text-[color:var(--color-ink)] truncate">R. Foster</div>
                    <div class="text-[0.68rem] text-[color:var(--color-slate-500)] mt-0.5 truncate">Today · 4:30 PM</div>
                    <div class="text-[0.62rem] text-[color:var(--color-ink)] mt-1 font-medium">Sewer camera</div>
                  </div>
                </div>
              </div>
              <!-- Done -->
              <div>
                <div class="flex items-center justify-between mb-3">
                  <span class="text-[0.72rem] font-bold uppercase tracking-wide text-[color:var(--color-slate-600)]">Done</span>
                  <span class="text-[0.7rem] font-semibold text-[color:var(--color-paper)] bg-[color:var(--color-accent)] px-2 py-0.5 rounded-full">14</span>
                </div>
                <div class="space-y-2">
                  <div class="bg-[color:var(--color-mint)] rounded-lg p-2.5 border border-[color:var(--color-accent-soft)]">
                    <div class="text-[0.78rem] font-semibold text-[color:var(--color-ink)] truncate">J. Lopez</div>
                    <div class="text-[0.68rem] text-[color:var(--color-slate-600)] mt-0.5 truncate">$1,840 · paid</div>
                    <div class="text-[0.62rem] text-[color:var(--color-warning)] mt-1 font-medium">★ 5-star · auto-asked</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Activity feed -->
            <div class="p-5 border-t lg:border-t-0 lg:border-l border-[color:var(--color-slate-200)]">
              <div class="text-[0.72rem] font-bold uppercase tracking-wide text-[color:var(--color-slate-600)] mb-3">Live activity</div>
              <ul class="space-y-3 text-[0.85rem]">
                <li class="flex gap-2.5">
                  <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-mint)] text-[color:var(--color-accent-dark)] text-[0.7rem] flex-shrink-0">SMS</span>
                  <div class="min-w-0">
                    <div class="text-[color:var(--color-ink)] truncate">Auto-text sent to A. Patel</div>
                    <div class="text-[0.7rem] text-[color:var(--color-slate-500)]">Just now</div>
                  </div>
                </li>
                <li class="flex gap-2.5">
                  <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-warning)]/15 text-[color:var(--color-warning)] text-[0.7rem] flex-shrink-0">★</span>
                  <div class="min-w-0">
                    <div class="text-[color:var(--color-ink)] truncate">New 5-star review · J. Lopez</div>
                    <div class="text-[0.7rem] text-[color:var(--color-slate-500)]">8 min ago</div>
                  </div>
                </li>
                <li class="flex gap-2.5">
                  <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-accent)]/15 text-[color:var(--color-accent-dark)] text-[0.7rem] flex-shrink-0">$</span>
                  <div class="min-w-0">
                    <div class="text-[color:var(--color-ink)] truncate">Job booked · D. Wong</div>
                    <div class="text-[0.7rem] text-[color:var(--color-slate-500)]">22 min ago</div>
                  </div>
                </li>
                <li class="flex gap-2.5">
                  <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-slate-100)] text-[color:var(--color-slate-500)] text-[0.7rem] flex-shrink-0">✆</span>
                  <div class="min-w-0">
                    <div class="text-[color:var(--color-ink)] truncate">Call from M. Soriano</div>
                    <div class="text-[0.7rem] text-[color:var(--color-slate-500)]">35 min ago</div>
                  </div>
                </li>
                <li class="flex gap-2.5">
                  <span class="grid place-items-center w-7 h-7 rounded-full bg-[color:var(--color-mint)] text-[color:var(--color-accent-dark)] text-[0.7rem] flex-shrink-0">SMS</span>
                  <div class="min-w-0">
                    <div class="text-[color:var(--color-ink)] truncate">Reply received · R. Foster</div>
                    <div class="text-[0.7rem] text-[color:var(--color-slate-500)]">1 hr ago</div>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-10">
        <a href="/contact" class="btn-accent">Book a demo →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- ═══ CANDIDATE SECTION 3 · VIDEO/GIF WALKTHROUGH PLACEHOLDER ══════════ -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[color:var(--color-cream)]">
    <div class="container-page section-padding">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="font-display text-[2.2rem] md:text-[3rem] lg:text-[3.4rem] leading-[1.05] tracking-tight text-[color:var(--color-ink)]">
          Watch the system catch a missed call live.
        </h2>
        <p class="mt-5 text-[1.05rem] leading-relaxed text-[color:var(--color-slate-600)] max-w-2xl mx-auto">
