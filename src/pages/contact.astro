---
import BaseLayout from "../layouts/BaseLayout.astro";

const trades: string[] = ["Plumbing · residential", "Plumbing · commercial", "Drain & sewer", "Emergency / 24-hour", "Other / multi-specialty"];
---

<BaseLayout
  title="Book a demo — JobsiteRank"
  description="Book a 20-minute demo with the JobsiteRank team. We'll pull up your Google Business Profile live and tell you straight which plan fits."
>
  <!-- ─── Header ─── -->
  <section class="bg-[color:var(--color-cream)] relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[color:var(--color-mint)]/40 via-transparent to-transparent pointer-events-none"></div>
    <div class="container-page relative section-padding-tight md:!pt-20 md:!pb-12">
      <div class="text-center max-w-3xl mx-auto">
        <span class="eyebrow-mint">Book a demo · 20 minutes</span>
        <h1 class="font-display text-[2.4rem] sm:text-[3.2rem] md:text-[3.8rem] leading-[1.05] tracking-tight mt-6 text-[color:var(--color-ink)]">
          Show me how it works.
        </h1>
        <p class="mt-6 text-[1.1rem] leading-relaxed text-[color:var(--color-slate-600)] max-w-2xl mx-auto">
          Twenty minutes. No pitch deck. We pull up your Google Business Profile live, audit your missed-call rate, and tell you straight whether JobsiteRank fits.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── Form + sidebar ─── -->
  <section class="bg-[color:var(--color-paper)]">
    <div class="container-page section-padding-tight md:!pt-12 md:!pb-24">
      <div class="grid lg:grid-cols-[1.5fr_1fr] gap-8 max-w-6xl mx-auto">

        <!-- Form card -->
        <div class="card-flat p-8 md:p-10">
          <div class="flex items-center justify-between mb-7">
            <h2 class="font-display text-[1.4rem] font-semibold text-[color:var(--color-ink)]">Tell us about your shop</h2>
            <span class="text-[0.85rem] text-[color:var(--color-slate-500)]">Takes 30 seconds</span>
          </div>

          <form class="grid gap-5" name="strategy-call" method="POST" action="#" autocomplete="on">
            <div>
              <label class="input-label" for="name">Your name</label>
              <input class="input-soft" type="text" id="name" name="name" required placeholder="Marco Diaz" />
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class="input-label" for="phone">Best phone</label>
                <input class="input-soft" type="tel" id="phone" name="phone" required placeholder="(626) 555-0142" />
              </div>
              <div>
                <label class="input-label" for="trade">Specialty</label>
                <select class="input-soft" id="trade" name="trade" required>
                  <option value="" disabled selected>Pick one</option>
                  {trades.map((t) => <option value={t}>{t}</option>)}
                </select>
              </div>
            </div>

            <div>
              <label class="input-label" for="email">Email <span class="text-[color:var(--color-slate-400)] font-normal text-[0.78rem] ml-1">(for the calendar link)</span></label>
              <input class="input-soft" type="email" id="email" name="email" required placeholder="marco@yourshop.com" />
            </div>

            <div>
              <label class="input-label" for="notes">What's going on? <span class="text-[color:var(--color-slate-400)] font-normal text-[0.78rem] ml-1">(optional, helps us prep)</span></label>
              <textarea class="input-soft" id="notes" name="notes" rows="4" placeholder="Spending on HomeAdvisor, want to stop. Map pack ranking is page 2. After-hours calls bouncing."></textarea>
            </div>

            <div class="pt-3 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
              <div class="text-[0.85rem] text-[color:var(--color-slate-500)] leading-snug">
                We text the calendar link within 1 business hour. No spam, no sales drip.
              </div>
              <button type="submit" class="btn-accent text-[0.95rem] !py-3 !px-6">
                Send →
              </button>
            </div>
          </form>

          <div class="mt-8 pt-6 border-t border-[color:var(--color-slate-200)] flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <span class="text-[0.9rem] text-[color:var(--color-slate-600)]">Prefer to skip the form?</span>
            <a href="tel:+16265550199" class="font-display text-[1.15rem] font-semibold text-[color:var(--color-ink)] hover:text-[color:var(--color-accent-dark)] transition-colors inline-flex items-center gap-2">
              <span>✆</span> (626) 555-0199
            </a>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="flex flex-col gap-5">
          <div class="card-mint">
            <div class="eyebrow mb-4">Direct line</div>
            <div class="space-y-5">
              <div>
                <div class="text-[0.85rem] font-semibold text-[color:var(--color-slate-600)] mb-1">By phone</div>
                <a href="tel:+16265550199" class="font-display text-[1.4rem] font-semibold text-[color:var(--color-ink)] hover:text-[color:var(--color-accent-dark)]">(626) 555-0199</a>
                <div class="text-[0.85rem] text-[color:var(--color-slate-500)] mt-1">Mon–Fri · 8a–6p PT</div>
              </div>
              <div class="border-t border-[color:var(--color-accent-soft)] pt-5">
                <div class="text-[0.85rem] font-semibold text-[color:var(--color-slate-600)] mb-1">By email</div>
                <a href="mailto:hello@jobsiterank.com" class="font-display text-[1.05rem] font-semibold text-[color:var(--color-ink)] hover:text-[color:var(--color-accent-dark)] break-all">hello@jobsiterank.com</a>
                <div class="text-[0.85rem] text-[color:var(--color-slate-500)] mt-1">Replies within 1 business hour</div>
              </div>
            </div>
          </div>

          <div class="card-dark">
            <div class="text-[color:var(--color-accent)] text-[0.78rem] font-semibold uppercase tracking-wide mb-4">What to expect</div>
            <ol class="space-y-4 text-[0.93rem]">
              <li class="flex gap-3">
                <span class="grid place-items-center w-6 h-6 rounded-full bg-[color:var(--color-accent)]/20 text-[color:var(--color-accent)] text-[0.78rem] font-bold flex-shrink-0 mt-0.5">1</span>
                <span class="text-[color:var(--color-paper)]/90">You submit. We confirm within 1 business hour with a calendar link.</span>
              </li>
              <li class="flex gap-3">
                <span class="grid place-items-center w-6 h-6 rounded-full bg-[color:var(--color-accent)]/20 text-[color:var(--color-accent)] text-[0.78rem] font-bold flex-shrink-0 mt-0.5">2</span>
                <span class="text-[color:var(--color-paper)]/90">20-minute call. We pull up your GBP and audit live.</span>
              </li>
              <li class="flex gap-3">
                <span class="grid place-items-center w-6 h-6 rounded-full bg-[color:var(--color-accent)]/20 text-[color:var(--color-accent)] text-[0.78rem] font-bold flex-shrink-0 mt-0.5">3</span>
                <span class="text-[color:var(--color-paper)]/90">Yes or no. If it's a fit, onboarding kicks off the next day.</span>
              </li>
            </ol>
          </div>

          <div class="card-flat">
            <div class="eyebrow mb-4">Service area</div>
            <ul class="space-y-2.5 text-[0.93rem] text-[color:var(--color-slate-700)]">
              <li class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)]"></span> Pasadena (HQ)</li>
              <li class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)]"></span> San Gabriel Valley</li>
              <li class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)]"></span> Greater Los Angeles</li>
              <li class="flex items-center gap-2.5"><span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-accent)]"></span> Plus 13 more states</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
