---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageMastHead from "../components/PageMastHead.astro";

const trades: string[] = ["Plumbing", "HVAC", "Roofing", "Electrical", "Other / not sure"];
---

<BaseLayout title="Contact — JobsiteRank" description="Book a 20-minute demo with the JobsiteRank team. Pasadena, San Gabriel Valley, Greater Los Angeles.">
  <PageMastHead
    fileTag="File 004"
    eyebrow="Intake form · Demo booking"
    title="Open the file."
  >
    <span slot="title">
      Open the file.<br />
      <span class="serif-italic text-[color:var(--color-amber)]">We'll do the rest.</span>
    </span>
    <p class="mt-8 max-w-2xl text-[color:var(--color-paper)]/80 text-[1.05rem] md:text-[1.15rem] leading-relaxed">
      Twenty minutes. No pitch deck. We pull up your Google Business Profile live on the call and tell you straight what we'd change first.
    </p>
  </PageMastHead>

  <section class="bg-[color:var(--color-paper)] -mt-12 relative z-10 pb-24">
    <div class="container-dossier grid lg:grid-cols-[1.5fr_1fr] gap-8">

      <!-- Form -->
      <div class="card-paper p-8 md:p-10">
        <div class="flex items-center justify-between mb-8">
          <span class="file-tag">Intake / 01</span>
          <span class="meta">Takes 30 seconds</span>
        </div>

        <form class="grid gap-6" name="strategy-call" method="POST" action="#" autocomplete="on">
          <div>
            <label class="input-label" for="name">Your name</label>
            <input class="input-dossier" type="text" id="name" name="name" required placeholder="Marco Diaz" />
          </div>

          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label class="input-label" for="phone">Best phone</label>
              <input class="input-dossier" type="tel" id="phone" name="phone" required placeholder="(626) 555-0142" />
            </div>
            <div>
              <label class="input-label" for="trade">Trade</label>
              <select class="input-dossier" id="trade" name="trade" required>
                <option value="" disabled selected>Pick one</option>
                {trades.map((t) => <option value={t}>{t}</option>)}
              </select>
            </div>
          </div>

          <div>
            <label class="input-label" for="email">Email <span class="text-[color:var(--color-ink)]/50 normal-case tracking-normal text-[0.65rem] ml-1">(for the calendar link)</span></label>
            <input class="input-dossier" type="email" id="email" name="email" required placeholder="marco@yourshop.com" />
          </div>

          <div>
            <label class="input-label" for="notes">What's going on? <span class="text-[color:var(--color-ink)]/50 normal-case tracking-normal text-[0.65rem] ml-1">(optional, helps us prep)</span></label>
            <textarea class="input-dossier" id="notes" name="notes" rows="4" placeholder="Spending on HomeAdvisor, want to stop. Map pack ranking is page 2. After-hours calls bouncing."></textarea>
          </div>

          <div class="pt-4 border-t border-[color:var(--color-rule)] flex flex-col sm:flex-row sm:items-center justify-between gap-5">
            <div class="meta">We text the calendar link within 1 business hour. No spam, no sales drip.</div>
            <button type="submit" class="btn-primary">
              Open the file
              <span aria-hidden="true">→</span>
            </button>
          </div>
        </form>

        <div class="mt-6 pt-6 border-t border-[color:var(--color-rule)] flex flex-col sm:flex-row sm:items-center justify-between gap-3">
          <div class="meta">Prefer to skip the form?</div>
          <a href="tel:+16265550199" class="font-display text-[1.15rem] font-semibold hover:text-[color:var(--color-amber-deep)]">
            <span aria-hidden="true" class="text-[0.85em] mr-1">✆</span>Call (626) 555-0199
          </a>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="flex flex-col gap-6">
        <div class="card-warm p-7">
          <span class="file-tag">Direct line</span>
          <div class="mt-5 space-y-5">
            <div>
              <div class="meta mb-1">By phone</div>
              <a href="tel:+16265550199" class="font-display text-[1.5rem] hover:text-[color:var(--color-amber-deep)]">(626) 555-0199</a>
              <div class="meta mt-1">Mon–Fri · 8a–6p PT</div>
            </div>
            <div class="border-t border-[color:var(--color-ink)]/15 pt-5">
              <div class="meta mb-1">By email</div>
              <a href="mailto:hello@jobsiterank.com" class="font-display text-[1.15rem] break-all hover:text-[color:var(--color-amber-deep)]">hello@jobsiterank.com</a>
              <div class="meta mt-1">Replies within one business hour</div>
            </div>
            <div class="border-t border-[color:var(--color-ink)]/15 pt-5">
              <div class="meta mb-1">By text</div>
              <a href="sms:+16265550199" class="font-display text-[1.15rem] hover:text-[color:var(--color-amber-deep)]">Text "DOSSIER" to (626) 555-0199</a>
              <div class="meta mt-1">Auto-replies with the booking link</div>
            </div>
          </div>
        </div>

        <div class="card-paper p-7">
          <span class="file-tag">Service area</span>
          <ul class="mt-5 space-y-2 text-[0.95rem]">
            <li class="flex items-baseline gap-3"><span class="text-[color:var(--color-amber-deep)]">●</span> Pasadena (HQ)</li>
            <li class="flex items-baseline gap-3"><span class="text-[color:var(--color-amber-deep)]">●</span> San Gabriel Valley</li>
            <li class="flex items-baseline gap-3"><span class="text-[color:var(--color-amber-deep)]">●</span> Greater Los Angeles</li>
          </ul>
          <div class="mt-5 pt-5 border-t border-[color:var(--color-rule)] meta">
            Outside this radius? Email us — we may be opening adjacent metros in the next quarter.
          </div>
        </div>

        <div class="dark-section p-7 relative overflow-hidden">
          <div class="grain"></div>
          <span class="file-tag">What to expect</span>
          <ol class="mt-5 space-y-4 text-[0.95rem]">
            <li class="flex gap-3"><span class="font-mono text-[0.72rem] tracking-[0.16em] text-[color:var(--color-amber)] mt-0.5">01</span><span>You submit. We confirm within one business hour with a calendar link.</span></li>
            <li class="flex gap-3"><span class="font-mono text-[0.72rem] tracking-[0.16em] text-[color:var(--color-amber)] mt-0.5">02</span><span>20-minute call. We pull up your GBP and audit live.</span></li>
            <li class="flex gap-3"><span class="font-mono text-[0.72rem] tracking-[0.16em] text-[color:var(--color-amber)] mt-0.5">03</span><span>Yes or no. If it's a fit, onboarding kicks off the next business day.</span></li>
          </ol>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
