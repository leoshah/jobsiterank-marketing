---
import BaseLayout from "../layouts/BaseLayout.astro";

const CALENDLY_URL = "https://calendly.com/gmbstrategysession/30min";
const CALENDLY_EMBED_URL = `${CALENDLY_URL}?hide_event_type_details=1&hide_gdpr_banner=1&primary_color=10b981&text_color=0e1b22`;
---

<BaseLayout
  title="Book a demo — JobsiteRank"
  description="Book a 20-minute demo with the JobsiteRank team. Pick a time that works for you — we'll pull up your Google Business Profile live and tell you straight which plan fits."
>
  <!-- ─── Header ─── -->
  <section class="bg-[color:var(--color-cream)] relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[color:var(--color-mint)]/40 via-transparent to-transparent pointer-events-none"></div>
    <div class="container-page relative section-padding-tight md:!pt-20 md:!pb-12">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="font-display text-[2.4rem] sm:text-[3.2rem] md:text-[3.8rem] leading-[1.05] tracking-tight text-[color:var(--color-ink)]">
          Pick a time. We'll show you how it works.
        </h1>
        <p class="mt-6 text-[1.1rem] leading-relaxed text-[color:var(--color-slate-600)] max-w-2xl mx-auto">
          Twenty minutes. No pitch deck. We pull up your Google Business Profile live, audit your missed-call rate, and tell you straight whether JobsiteRank fits.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── Calendly + What to expect (stacked) ─── -->
  <section class="bg-[color:var(--color-paper)]">
    <div class="container-page section-padding-tight md:!pt-12 md:!pb-24">
      <div class="max-w-3xl mx-auto space-y-8">

        <!-- Calendly inline embed (height grows with content, page scrolls through it) -->
        <div
          id="calendly-wrap"
          class="rounded-2xl border border-[color:var(--color-slate-200)] bg-[color:var(--color-paper)] overflow-hidden"
        >
          <div
            id="calendly-inline"
            class="calendly-inline-widget"
            data-url={CALENDLY_EMBED_URL}
            style="min-width:320px; min-height:1100px; height:1100px;"
          ></div>
        </div>

        <script is:inline>
          // Listen for Calendly's postMessage size events and resize the iframe
          // so the widget never has its own internal scrollbar — the page scrolls through it.
          (function () {
            const wrap = document.getElementById("calendly-inline");
            if (!wrap) return;

            function isCalendlyMsg(e) {
              return (
                e.origin === "https://calendly.com" &&
                e.data &&
                typeof e.data.event === "string" &&
                e.data.event.indexOf("calendly.") === 0
              );
            }

            window.addEventListener("message", function (e) {
              if (!isCalendlyMsg(e)) return;
              const payload = e.data.payload || {};
              const h = payload.height || (payload.iframe && payload.iframe.height);
              if (typeof h === "number" && h > 600) {
                wrap.style.height = h + 40 + "px";
              }
            });
          })();
        </script>

        <!-- What to expect (below the calendar) -->
        <div class="card-dark">
          <div class="text-[color:var(--color-accent)] text-[0.78rem] font-semibold uppercase tracking-wide mb-5">What to expect</div>
          <ol class="grid sm:grid-cols-3 gap-5 text-[0.95rem]">
            <li class="flex flex-col gap-3">
              <span class="grid place-items-center w-9 h-9 rounded-full bg-[color:var(--color-accent)]/20 text-[color:var(--color-accent)] text-[0.95rem] font-bold flex-shrink-0">1</span>
              <span class="text-[color:var(--color-paper)]/90 leading-relaxed">Pick a 20-minute slot. We send the calendar invite + Zoom link instantly.</span>
            </li>
            <li class="flex flex-col gap-3">
              <span class="grid place-items-center w-9 h-9 rounded-full bg-[color:var(--color-accent)]/20 text-[color:var(--color-accent)] text-[0.95rem] font-bold flex-shrink-0">2</span>
              <span class="text-[color:var(--color-paper)]/90 leading-relaxed">On the call — we pull up your Google Business Profile and audit live.</span>
            </li>
            <li class="flex flex-col gap-3">
              <span class="grid place-items-center w-9 h-9 rounded-full bg-[color:var(--color-accent)]/20 text-[color:var(--color-accent)] text-[0.95rem] font-bold flex-shrink-0">3</span>
              <span class="text-[color:var(--color-paper)]/90 leading-relaxed">Yes or no. If it's a fit, onboarding kicks off the next day.</span>
            </li>
          </ol>
        </div>

      </div>
    </div>
  </section>

  <!-- Calendly widget script (loaded once on this page) -->
  <script
    is:inline
    type="text/javascript"
    src="https://assets.calendly.com/assets/external/widget.js"
    async
  ></script>
</BaseLayout>
